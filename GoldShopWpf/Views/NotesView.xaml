<UserControl x:Class="GoldShopWpf.Views.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="NotesCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource GridCellTextStyle}">
            <Setter Property="ToolTip" Value="{Binding Content}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,18"
                Padding="28"
                CornerRadius="28"
                BorderBrush="#D8E5FF"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F5F9FF" Offset="0" />
                    <GradientStop Color="#EAF2FF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="{DynamicResource NavNotes}" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{DynamicResource LblNotesPageSub}"
                               FontSize="15"
                               Foreground="#53647F"
                               Margin="0,0,0,18" />
                </StackPanel>

                <Button Grid.Row="0"
                        Grid.Column="1"
                        Command="{Binding AddCommand}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="164"
                        HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource BtnAddNote}" />
                    </StackPanel>
                </Button>

                <Grid Grid.Row="1" Grid.ColumnSpan="2">
                    <Border MaxWidth="520"
                            MinWidth="320"
                            Background="#FFFFFF"
                            BorderBrush="#D8E5FF"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="16,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=FlowDirection}" Value="LeftToRight">
                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Margin="0"
                                     MinHeight="44"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{DynamicResource LblSearch}"
                                     materialDesign:HintAssist.Hint="{DynamicResource LblSearch}" />
                            <materialDesign:PackIcon Grid.Column="1"
                                                     Kind="Magnify"
                                                     Width="22"
                                                     Height="22"
                                                     VerticalAlignment="Center"
                                                     HorizontalAlignment="Center"
                                                     Margin="12,0,0,0" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardContainer}" BorderBrush="#E7ECF2">
            <Grid IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource LblNotesRegister}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding TotalRecords, StringFormat=عدد الملاحظات: {0}}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                        <Button Command="{Binding RefreshCommand}" Style="{StaticResource GhostButton}" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnRefresh}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding EditCommand}" Style="{StaticResource GhostButton}" Margin="0,0,10,0" MinWidth="118">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnEdit}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DeleteCommand}" Style="{StaticResource GhostButton}" MinWidth="156">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Margin="0,0,6,0" Foreground="#D32F2F" />
                                <TextBlock Text="{DynamicResource BtnDeleteMultiple}" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <DataGrid ItemsSource="{Binding Notes}"
                              SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              CanUserSortColumns="True"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              FrozenColumnCount="1"
                              KeyboardNavigation.TabNavigation="Continue"
                              ScrollViewer.IsDeferredScrollingEnabled="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="68" MinWidth="68" SortMemberPath="IsSelected">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <CheckBox IsThreeState="True"
                                                  IsChecked="{Binding DataContext.AreAllVisibleSelected, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  ToolTip="{DynamicResource LblSelectAll}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Focusable="True" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource LblClientName}"
                                                Binding="{Binding ClientName}"
                                                SortMemberPath="ClientName"
                                                Width="1.2*"
                                                MinWidth="140"
                                                ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTemplateColumn Header="{DynamicResource LblNoteContent}" SortMemberPath="Content" Width="2*" MinWidth="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Content}"
                                                   ToolTip="{Binding Content}"
                                                   Style="{StaticResource GridCellTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource LblCreatedAt}"
                                                Binding="{Binding CreatedAt, StringFormat={}{0:yyyy/MM/dd hh:mm tt}}"
                                                SortMemberPath="CreatedAt"
                                                Width="1.1*"
                                                MinWidth="150"
                                                ElementStyle="{StaticResource GridCellTextStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Background="#FAFBFE"
                            BorderBrush="#E7ECF2"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Notes.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Width="320">
                            <materialDesign:PackIcon Kind="NotebookOutline" Width="44" Height="44" HorizontalAlignment="Center" Foreground="#5B7DBB" />
                            <TextBlock Text="{DynamicResource LblNoNotes}" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" Margin="0,14,0,8" />
                            <TextBlock Text="{DynamicResource LblNoNotesSub}" Foreground="{StaticResource MutedTextBrush}" TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1,1,1,0" Padding="10,8">
                    <WrapPanel>
                        <Border Padding="12,8" Background="#FFFFFF" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="12" Margin="0,0,12,8">
                            <TextBlock Text="{Binding RowsCountLabel}" FontWeight="SemiBold" Foreground="#344054" />
                        </Border>
                        <Border Padding="12,8" Background="#FFFFFF" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="12" Margin="0,0,8,8">
                            <TextBlock Text="{Binding PageSummary}" FontWeight="SemiBold" Foreground="#344054" />
                        </Border>
                        <WrapPanel>
                            <Button Command="{Binding PreviousPageCommand}" Style="{StaticResource CompactToolbarButton}" MinWidth="74" Margin="0,0,8,8">
                                <TextBlock Text="{DynamicResource BtnPreviousPage}" />
                            </Button>
                            <Button Command="{Binding NextPageCommand}" Style="{StaticResource CompactToolbarButton}" MinWidth="74" Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource BtnNextPage}" />
                            </Button>
                        </WrapPanel>
                    </WrapPanel>
                </Border>

                <Border Grid.RowSpan="3" Visibility="{Binding IsBusyVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#B3FFFFFF">
                    <Border Style="{StaticResource LoadingOverlayCard}">
                        <StackPanel>
                            <ProgressBar IsIndeterminate="True" Width="180" Height="6" Margin="0,0,0,14" />
                            <TextBlock Text="{Binding BusyMessage}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
