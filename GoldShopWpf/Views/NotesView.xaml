<UserControl x:Class="GoldShopWpf.Views.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="NotesCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource GridCellTextStyle}">
            <Setter Property="ToolTip" Value="{Binding Content}" />
        </Style>
        <Style x:Key="GridActionMenu" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FlowDirection" Value="LeftToRight" />
        </Style>
        <Style x:Key="GridActionMenuItem" TargetType="MenuItem">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,8"
                Padding="12,10"
                CornerRadius="18"
                BorderBrush="#D8E5FF"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F5F9FF" Offset="0" />
                    <GradientStop Color="#EAF2FF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{DynamicResource NavNotes}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                <Border Grid.Column="2"
                        MaxWidth="560"
                        MinWidth="300"
                        Background="#FFFFFF"
                        BorderBrush="#D8E5FF"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Margin="0"
                                 MinHeight="38"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="{DynamicResource LblSearch}"
                                 materialDesign:HintAssist.Hint="{DynamicResource LblSearch}" />
                        <materialDesign:PackIcon Grid.Column="1"
                                                 Kind="Magnify"
                                                 Width="20"
                                                 Height="20"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"
                                                 Margin="10,0,0,0" />
                    </Grid>
                </Border>

                <WrapPanel Grid.Column="4" VerticalAlignment="Center">
                    <Button Command="{Binding AddCommand}"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="132"
                            Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource BtnAddNote}" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardContainer}" BorderBrush="#E7ECF2" Padding="8">
            <Grid IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CompactCommandBar}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <WrapPanel>
                            <Button Command="{Binding AddCommand}" Style="{StaticResource CompactPrimaryToolbarButton}" MinWidth="132" Height="38">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Margin="0,0,6,0" />
                                    <TextBlock Text="{DynamicResource BtnAdd}" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                        <Menu Grid.Column="1" Style="{StaticResource GridActionMenu}">
                            <MenuItem Header="{DynamicResource BtnMore}" Style="{StaticResource GridActionMenuItem}">
                                <MenuItem Header="{DynamicResource BtnEdit}" Command="{Binding EditCommand}" />
                                <MenuItem Header="{DynamicResource BtnDeleteMultiple}" Command="{Binding DeleteCommand}" />
                                <MenuItem Header="{DynamicResource BtnClearSelection}" Command="{Binding ClearSelectionCommand}" />
                                <Separator />
                                <MenuItem Header="{DynamicResource BtnRefresh}" Command="{Binding RefreshCommand}" />
                            </MenuItem>
                        </Menu>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <DataGrid ItemsSource="{Binding Notes}"
                              SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              CanUserSortColumns="True"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              FrozenColumnCount="1"
                              KeyboardNavigation.TabNavigation="Continue"
                              ScrollViewer.IsDeferredScrollingEnabled="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="68" MinWidth="68" SortMemberPath="IsSelected">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <CheckBox IsThreeState="False"
                                                  IsChecked="{Binding DataContext.AreAllVisibleSelected, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=OneWay}"
                                                  Click="OnSelectAllClicked"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  ToolTip="{DynamicResource LblSelectAll}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Focusable="True" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource LblClientName}"
                                                Binding="{Binding ClientName}"
                                                SortMemberPath="ClientName"
                                                Width="1.2*"
                                                MinWidth="140"
                                                ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTemplateColumn Header="{DynamicResource LblNoteContent}" SortMemberPath="Content" Width="2*" MinWidth="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Content}"
                                                   ToolTip="{Binding Content}"
                                                   Style="{StaticResource GridCellTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource LblCreatedAt}"
                                                Binding="{Binding CreatedAt, StringFormat={}{0:yyyy/MM/dd hh:mm tt}}"
                                                SortMemberPath="CreatedAt"
                                                Width="1.1*"
                                                MinWidth="150"
                                                ElementStyle="{StaticResource GridCellTextStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Background="#FAFBFE"
                            BorderBrush="#E7ECF2"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Notes.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Width="320">
                            <materialDesign:PackIcon Kind="NotebookOutline" Width="44" Height="44" HorizontalAlignment="Center" Foreground="#5B7DBB" />
                            <TextBlock Text="{DynamicResource LblNoNotes}" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" Margin="0,14,0,8" />
                            <TextBlock Text="{DynamicResource LblNoNotesSub}" Foreground="{StaticResource MutedTextBrush}" TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1,1,1,0" Padding="10,8" Margin="0,6,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Padding="12,8" Background="#FFFFFF" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="12" Margin="0,0,12,0" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding RowsCountLabel}" FontWeight="SemiBold" Foreground="#344054" />
                        </Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Padding="12,8" Background="#FFFFFF" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="12" Margin="0,0,8,0">
                                <TextBlock Text="{Binding PageSummary}" FontWeight="SemiBold" Foreground="#344054" />
                            </Border>
                            <Border Padding="12,8" Background="#FFF7E2" BorderBrush="#F0DFA7" BorderThickness="1" CornerRadius="12">
                                <TextBlock Text="{Binding SelectedCountLabel}" FontWeight="SemiBold" Foreground="#8A6C00" />
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Command="{Binding PreviousPageCommand}" Style="{StaticResource CompactToolbarButton}" MinWidth="74" Margin="0,0,8,0">
                                <TextBlock Text="{DynamicResource BtnPreviousPage}" />
                            </Button>
                            <Button Command="{Binding NextPageCommand}" Style="{StaticResource CompactToolbarButton}" MinWidth="74" Margin="0">
                                <TextBlock Text="{DynamicResource BtnNextPage}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.RowSpan="3" Visibility="{Binding IsBusyVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#B3FFFFFF">
                    <Border Style="{StaticResource LoadingOverlayCard}">
                        <StackPanel>
                            <ProgressBar IsIndeterminate="True" Width="180" Height="6" Margin="0,0,0,14" />
                            <TextBlock Text="{Binding BusyMessage}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
