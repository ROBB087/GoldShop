<UserControl x:Class="GoldShopWpf.Views.SuppliersView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="HeaderTitleIconWrap" TargetType="Border">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="52" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="#1F3B73" />
            <Setter Property="BorderBrush" Value="#4A6FB3" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="StatChip" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D8E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>

        <Style x:Key="HeaderActionButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Height" Value="44" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Padding" Value="16,8" />
        </Style>

        <Style x:Key="BulkActionButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActionsMenu" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FlowDirection" Value="LeftToRight" />
        </Style>

        <Style x:Key="ActionsMenuItem" TargetType="MenuItem">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardContainer}"
                Margin="0,0,0,16"
                Padding="24"
                BorderBrush="#C9D5E6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F5F8FC" Offset="0" />
                    <GradientStop Color="#E8F0FB" Offset="0.55" />
                    <GradientStop Color="#F2F7FF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Grid.ColumnSpan="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            FlowDirection="LeftToRight">
                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource HeaderActionButton}"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Margin="0,0,6,0" />
                            <TextBlock Text="تحديث" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding AddCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Height="44"
                            MinWidth="152"
                            Padding="18,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Margin="0,0,6,0" />
                            <TextBlock Text="إضافة تاجر" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Column="4"
                        Grid.ColumnSpan="4"
                        Height="48"
                        Margin="16,0"
                        Padding="14,0"
                        Background="#FAFBFC"
                        BorderBrush="#DCE3EC"
                        BorderThickness="1"
                        CornerRadius="14"
                        VerticalAlignment="Center">
                    <Grid FlowDirection="RightToLeft">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0"
                                                 Kind="Magnify"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"
                                                 Foreground="#667085" />
                        <TextBox Grid.Column="1"
                                 Margin="0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MinHeight="36"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="ابحث باسم التاجر أو الهاتف"
                                 materialDesign:HintAssist.Hint="ابحث باسم التاجر أو الهاتف" />
                    </Grid>
                </Border>

                <Grid Grid.Column="8"
                      Grid.ColumnSpan="4"
                      HorizontalAlignment="Right"
                      FlowDirection="RightToLeft">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Style="{StaticResource HeaderTitleIconWrap}"
                            Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="AccountGroupOutline"
                                                 Width="24"
                                                 Height="24"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Foreground="White" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                FlowDirection="RightToLeft"
                                VerticalAlignment="Center">
                        <TextBlock Text="التجار"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="شاشة تشغيل يومية سريعة لإدارة بيانات التجار والأرصدة وفتح السجلات من مكان واحد."
                                   FontSize="13"
                                   Foreground="#475467" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,16" FlowDirection="LeftToRight">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="8"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource StatChip}">
                <Grid FlowDirection="RightToLeft">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="40"
                            Height="40"
                            Background="#E8EEF9"
                            CornerRadius="14"
                            Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="AccountMultipleOutline"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Foreground="#31548F" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                FlowDirection="RightToLeft">
                        <TextBlock Text="إجمالي التجار"
                                   FontSize="12"
                                   Foreground="#667085" />
                        <TextBlock Text="{Binding TotalSuppliers}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="10"
                    Grid.ColumnSpan="2"
                    Style="{StaticResource StatChip}"
                    Margin="0">
                <Grid FlowDirection="RightToLeft">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="40"
                            Height="40"
                            Background="#EEF4EA"
                            CornerRadius="14"
                            Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="ViewListOutline"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Foreground="#3D7A42" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                FlowDirection="RightToLeft">
                        <TextBlock Text="المعروض حالياً"
                                   FontSize="12"
                                   Foreground="#667085" />
                        <TextBlock Text="{Binding VisibleSuppliersCount}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource CardContainer}"
                Margin="0"
                Padding="0"
                BorderBrush="#E5EAF1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="24,24,24,16" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="8"
                          Grid.ColumnSpan="4"
                          HorizontalAlignment="Right"
                          FlowDirection="RightToLeft">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Width="40"
                                Height="40"
                                Background="#F2F4F7"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="TableLarge"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="#344054" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    FlowDirection="RightToLeft">
                            <TextBlock Text="دليل التجار"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="جدول بيانات موحد لعرض الأسماء والهواتف والأرصدة وآخر النشاط مع تنفيذ الإجراءات بسرعة."
                                       FontSize="13"
                                       Foreground="#667085"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="0"
                                Grid.ColumnSpan="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                FlowDirection="LeftToRight">
                        <Border Padding="12,8"
                                Margin="0,0,8,0"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock Text="{Binding VisibleSuppliersCount, StringFormat=السجلات المعروضة: {0}}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#475467" />
                        </Border>

                        <Border Padding="12,6"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12">
                            <CheckBox IsChecked="{Binding IsCompactDensity}"
                                      VerticalAlignment="Center"
                                      FlowDirection="RightToLeft"
                                      Content="كثافة مدمجة" />
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Margin="24,0,24,16"
                        Padding="16,12"
                        Background="#FFF8E6"
                        BorderBrush="#F1DEAB"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid FlowDirection="LeftToRight">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <WrapPanel Grid.Column="0"
                                   Orientation="Horizontal"
                                   HorizontalAlignment="Left"
                                   FlowDirection="LeftToRight"
                                   VerticalAlignment="Center">
                            <Button Command="{Binding OpenDetailsCommand}"
                                    Style="{StaticResource BulkActionButton}">
                                <TextBlock Text="عرض التفاصيل" />
                            </Button>
                            <Button Command="{Binding EditCommand}"
                                    Style="{StaticResource BulkActionButton}">
                                <TextBlock Text="تعديل" />
                            </Button>
                            <Button Command="{Binding DeleteCommand}"
                                    Style="{StaticResource BulkActionButton}"
                                    Foreground="#B42318">
                                <TextBlock Text="حذف" />
                            </Button>
                            <Button Command="{Binding ClearSelectionCommand}"
                                    Style="{StaticResource BulkActionButton}"
                                    Margin="0">
                                <TextBlock Text="إلغاء التحديد" />
                            </Button>
                        </WrapPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedCountLabel}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="#8A6C00" />
                    </Grid>
                </Border>

                <DataGrid Grid.Row="2"
                          Margin="0,0,0,8"
                          ItemsSource="{Binding FilteredSuppliers}"
                          SelectedItem="{Binding SelectedSupplier}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserSortColumns="True"
                          IsReadOnly="True"
                          RowHeight="{Binding TableRowHeight}"
                          ColumnHeaderHeight="{Binding TableHeaderHeight}"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="56" CanUserSort="False">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <CheckBox IsThreeState="False"
                                              IsChecked="{Binding DataContext.AreAllVisibleSelected, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=OneWay}"
                                              Click="OnSelectAllClicked"
                                              ToolTip="{DynamicResource LblSelectAllRecords}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="اسم التاجر" Width="2.3*" MinWidth="240" SortMemberPath="Name">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="8,0"
                                                FlowDirection="RightToLeft"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="سجل تاجر"
                                                   FontSize="11"
                                                   Foreground="#98A2B3"
                                                   Margin="0,2,0,0"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="الهاتف" Width="1.35*" MinWidth="160" SortMemberPath="Phone">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Phone}"
                                               Margin="8,0"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="رصيد الذهب (21)" Width="1.9*" MinWidth="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="8,0"
                                                FlowDirection="RightToLeft"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding NetGold21, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#7A5C00"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center" />
                                        <TextBlock Text="{Binding TotalGold21, StringFormat=إجمالي {0:0.####} جم}"
                                                   FontSize="11"
                                                   Foreground="#667085"
                                                   Margin="0,2,0,0"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="آخر تحديث" Width="1.5*" MinWidth="180" SortMemberPath="LastActivityLabel">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="8,0"
                                                FlowDirection="RightToLeft"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding LastActivityLabel}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center" />
                                        <TextBlock Text="آخر نشاط مسجل"
                                                   FontSize="11"
                                                   Foreground="#98A2B3"
                                                   Margin="0,2,0,0"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="⋮" Width="72" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Menu Style="{StaticResource ActionsMenu}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <MenuItem Header="⋮"
                                                  Style="{StaticResource ActionsMenuItem}">
                                            <MenuItem Header="عرض التفاصيل"
                                                      Command="{Binding DataContext.OpenRowDetailsCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="تعديل"
                                                      Command="{Binding DataContext.EditRowCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="حذف"
                                                      Foreground="#B42318"
                                                      Command="{Binding DataContext.DeleteRowCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                        </MenuItem>
                                    </Menu>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
