<UserControl x:Class="GoldShopWpf.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,18"
                Padding="28"
                CornerRadius="28"
                BorderBrush="#E3EAF5"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F7FAFF" Offset="0" />
                    <GradientStop Color="#EEF4FF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="360"
                        Background="#FFFFFF"
                        BorderBrush="#DCE6F5"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="14,10"
                        VerticalAlignment="Center"
                        Margin="0,42,24,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Width="290"
                                 Margin="0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="{DynamicResource LblSearch}"
                                 materialDesign:HintAssist.Hint="{DynamicResource LblSearch}" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{DynamicResource NavSuppliers}" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{DynamicResource LblManageTradersSub}"
                               FontSize="15"
                               Foreground="#526077"
                               Margin="0,0,0,18" />
                    <WrapPanel>
                        <Button Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" MinWidth="152">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnAddTrader}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding EditCommand}" Style="{StaticResource GhostButton}" Margin="0,0,10,0" MinWidth="118">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnEdit}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DeleteCommand}" Style="{StaticResource GhostButton}" Margin="0,0,10,0" MinWidth="118">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnDelete}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenDetailsCommand}" Style="{StaticResource GhostButton}" MinWidth="148">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="OpenInNew" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnViewDetails}" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardContainer}"
                BorderBrush="#E7ECF2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LblTraderDirectory}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{DynamicResource LblTraderDirectorySub}"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Padding="12,8"
                            CornerRadius="14"
                            Background="#F6F8FC"
                            BorderBrush="#E3EAF5"
                            BorderThickness="1">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="#4D5B73">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding FilteredSuppliers.Count, StringFormat=Visible Traders: {0}}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=FlowDirection}" Value="RightToLeft">
                                            <Setter Property="Text" Value="{Binding FilteredSuppliers.Count, StringFormat=التجار الظاهرون: {0}}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding FilteredSuppliers}"
                          SelectedItem="{Binding SelectedSupplier}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource LblTrader}" Binding="{Binding Name}" Width="*" MinWidth="220" ElementStyle="{StaticResource GridCellTextStyle}" />
                        <DataGridTextColumn Header="{DynamicResource LblPhone}" Binding="{Binding Phone}" Width="180" MinWidth="180" ElementStyle="{StaticResource GridCellTextStyle}" />
                        <DataGridTextColumn Header="{DynamicResource LblTotalGold21}" Binding="{Binding TotalGold21, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}" Width="180" MinWidth="180" ElementStyle="{StaticResource GridCellTextStyle}" />
                        <DataGridTextColumn Header="{DynamicResource LblNetGold21}" Binding="{Binding NetGold21, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}" Width="180" MinWidth="180" ElementStyle="{StaticResource GridCellTextStyle}" />
                        <DataGridTextColumn Header="{DynamicResource LblLastUpdated}" Binding="{Binding LastActivityLabel}" Width="200" MinWidth="200" ElementStyle="{StaticResource GridCellTextStyle}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
