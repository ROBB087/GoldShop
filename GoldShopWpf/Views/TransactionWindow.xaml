<Window x:Class="GoldShopWpf.Views.TransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Transaction" Height="620" Width="620" MinWidth="400" MinHeight="300" WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        FlowDirection="{DynamicResource AppFlowDirection}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="{DynamicResource LblTrader}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="8" />
        <ComboBox x:Name="SupplierCombo" Grid.Row="0" Grid.Column="1" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,8" MinHeight="30" />

        <TextBlock Text="{DynamicResource LblDate}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="8" />
        <DatePicker x:Name="DatePicker" Grid.Row="1" Grid.Column="1" Margin="0,8" MinHeight="30" />

        <TextBlock Text="{DynamicResource LblType}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="8" />
        <ComboBox x:Name="TypeCombo" Grid.Row="2" Grid.Column="1" Margin="0,8" MinHeight="30" DisplayMemberPath="Label" SelectedValuePath="Type" />

        <TextBlock Text="{DynamicResource LblWeight}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="8" />
        <TextBox x:Name="WeightText" Grid.Row="3" Grid.Column="1" Margin="0,8" MinHeight="30" />

        <TextBlock Text="{DynamicResource LblKarat}" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="8" />
        <ComboBox x:Name="KaratCombo" Grid.Row="4" Grid.Column="1" Margin="0,8" MinHeight="30" />

        <TextBlock Text="{DynamicResource LblManufacturingPerGram}" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="8" />
        <TextBox x:Name="ManufacturingText" Grid.Row="5" Grid.Column="1" Margin="0,8" MinHeight="30" />

        <TextBlock Text="{DynamicResource LblImprovementPerGram}" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Margin="8" />
        <TextBox x:Name="ImprovementText" Grid.Row="6" Grid.Column="1" Margin="0,8" MinHeight="30" />

        <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8" Padding="12" Background="#FFF8E1" CornerRadius="8">
            <StackPanel>
                <TextBlock x:Name="EquivalentText" FontWeight="SemiBold" Foreground="#8D6E63" />
                <TextBlock x:Name="ManufacturingTotalText" Foreground="#8D6E63" Margin="0,4,0,0" />
                <TextBlock x:Name="ImprovementTotalText" Foreground="#8D6E63" Margin="0,4,0,0" />
                <TextBlock x:Name="TraceabilityText" Foreground="#6D4C41" Margin="0,6,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <TextBlock Text="{DynamicResource LblNotes}" Grid.Row="8" Grid.Column="0" VerticalAlignment="Top" Margin="8" />
        <TextBox x:Name="NotesText" Grid.Row="8" Grid.Column="1" Margin="0,8" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" />

        <StackPanel Orientation="Horizontal" Grid.Row="9" Grid.Column="1" HorizontalAlignment="Right" Margin="8,16,0,0">
            <Button Style="{StaticResource PrimaryButton}" Margin="8,16,0,0" Click="OnSave">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="{DynamicResource BtnApply}" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource GhostButton}" Margin="8,16,0,0" Click="OnCancel">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CloseCircle" Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="{DynamicResource BtnClear}" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
