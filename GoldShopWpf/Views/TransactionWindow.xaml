<Window x:Class="GoldShopWpf.Views.TransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transaction" Height="520" Width="520" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="{DynamicResource LblSupplier}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
        <ComboBox x:Name="SupplierCombo" Grid.Row="0" Grid.Column="1" Height="32" DisplayMemberPath="Name" SelectedValuePath="Id" />

        <TextBlock Text="{DynamicResource LblDate}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0" />
        <DatePicker x:Name="DatePicker" Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" />

        <TextBlock Text="{DynamicResource LblType}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0" />
        <ComboBox x:Name="TypeCombo" Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Height="32" SelectionChanged="OnTypeChanged" DisplayMemberPath="Label" SelectedValuePath="Type" />

        <TextBlock x:Name="WeightLabel" Text="{DynamicResource LblWeight}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0" />
        <TextBox x:Name="WeightText" Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Height="32" />

        <TextBlock x:Name="PurityLabel" Text="{DynamicResource LblPurity}" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0" />
        <TextBox x:Name="PurityText" Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Height="32" />

        <TextBlock Text="{DynamicResource LblAmount}" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,10,0,0" />
        <TextBox x:Name="AmountText" Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Height="32" />

        <TextBlock Text="{DynamicResource LblNotes}" Grid.Row="6" Grid.Column="0" VerticalAlignment="Top" Margin="0,10,0,0" />
        <TextBox x:Name="NotesText" Grid.Row="6" Grid.Column="1" Margin="0,10,0,0" AcceptsReturn="True" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" Grid.Row="7" Grid.Column="1" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{DynamicResource BtnApply}" Width="120" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="OnSave" ToolTip="{DynamicResource BtnApply}" />
            <Button Content="{DynamicResource BtnClear}" Width="100" Style="{StaticResource GhostButton}" Click="OnCancel" ToolTip="{DynamicResource BtnClear}" />
        </StackPanel>
    </Grid>
</Window>
