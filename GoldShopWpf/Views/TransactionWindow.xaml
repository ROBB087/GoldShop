<Window x:Class="GoldShopWpf.Views.TransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource WindowAddTransaction}"
        Height="940"
        Width="660"
        MinWidth="580"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FlowDirection="{DynamicResource AppFlowDirection}">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="20,20,20,0"
                Padding="24"
                CornerRadius="24"
                Background="#FFF9EC"
                BorderBrush="#F1E0A9"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Border Width="54" Height="54" CornerRadius="16" Background="#FFE8A3">
                    <materialDesign:PackIcon Kind="CashFast" Width="24" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0">
                    <TextBlock x:Name="HeaderTitleText" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="{DynamicResource SubTransactionWindow}" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardContainer}" Margin="20,20,20,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{DynamicResource LblTrader}" Grid.Row="0" Grid.Column="0" Margin="8,12" />
                    <ComboBox x:Name="SupplierCombo" Style="{StaticResource SearchableTraderComboBox}" Grid.Row="0" Grid.Column="1" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,8" />

                    <TextBlock Text="{DynamicResource LblDate}" Grid.Row="1" Grid.Column="0" Margin="8,12" />
                    <DatePicker x:Name="DatePicker" Grid.Row="1" Grid.Column="1" Margin="0,8" HorizontalAlignment="Stretch" />

                    <TextBlock Text="{DynamicResource LblTransactionCategory}" Grid.Row="2" Grid.Column="0" Margin="8,12" />
                    <ComboBox x:Name="TypeCombo" Grid.Row="2" Grid.Column="1" Margin="0,8" DisplayMemberPath="Label" SelectedValuePath="Category" />

                    <TextBlock x:Name="WeightLabel" Text="{DynamicResource LblWeight}" Grid.Row="3" Grid.Column="0" Margin="8,12" />
                    <TextBox x:Name="WeightText" Grid.Row="3" Grid.Column="1" Margin="0,8" />

                    <TextBlock x:Name="ItemLabel" Text="{DynamicResource LblItem}" Grid.Row="4" Grid.Column="0" Margin="8,12" />
                    <TextBox x:Name="ItemText" Grid.Row="4" Grid.Column="1" Margin="0,8" TabIndex="4" />

                    <TextBlock x:Name="KaratLabel" Text="{DynamicResource LblKarat}" Grid.Row="5" Grid.Column="0" Margin="8,12" />
                    <ComboBox x:Name="KaratCombo" Grid.Row="5" Grid.Column="1" Margin="0,8" />

                    <TextBlock x:Name="ManufacturingLabel" Text="{DynamicResource LblManufacturingPerGram}" Grid.Row="6" Grid.Column="0" Margin="8,12" />
                    <TextBox x:Name="ManufacturingText" Grid.Row="6" Grid.Column="1" Margin="0,8" />

                    <TextBlock x:Name="ImprovementLabel" Text="{DynamicResource LblImprovementPerGram}" Grid.Row="7" Grid.Column="0" Margin="8,12" />
                    <TextBox x:Name="ImprovementText" Grid.Row="7" Grid.Column="1" Margin="0,8" />

                    <Border Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12" Padding="16" Background="#FFF8E1" CornerRadius="16" BorderBrush="#F2DDA6" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0">
                                <Border Margin="6" Padding="12,10" Background="#FFFDF6" BorderBrush="#EAD8A4" BorderThickness="1" CornerRadius="12">
                                    <TextBlock x:Name="EquivalentText" FontSize="13" FontWeight="SemiBold" Foreground="#8D6E63" TextAlignment="Center" />
                                </Border>
                                <Border Margin="6" Padding="12,10" Background="#FFFDF6" BorderBrush="#EAD8A4" BorderThickness="1" CornerRadius="12">
                                    <TextBlock x:Name="ManufacturingTotalText" FontSize="13" Foreground="#8D6E63" TextAlignment="Center" />
                                </Border>
                                <Border Margin="6" Padding="12,10" Background="#FFFDF6" BorderBrush="#EAD8A4" BorderThickness="1" CornerRadius="12">
                                    <TextBlock x:Name="ImprovementTotalText" FontSize="13" Foreground="#8D6E63" TextAlignment="Center" />
                                </Border>
                            </WrapPanel>

                            <Border Grid.Row="1" Margin="6,10,6,0" Padding="12,10" Background="#FFFDF6" BorderBrush="#EAD8A4" BorderThickness="1" CornerRadius="12">
                                <TextBlock x:Name="TraceabilityText" FontSize="12" Foreground="#6D4C41" TextWrapping="Wrap" TextAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <TextBlock Text="{DynamicResource LblNotes}" Grid.Row="9" Grid.Column="0" Margin="8,12" VerticalAlignment="Top" />
                    <TextBox x:Name="NotesText" Grid.Row="9" Grid.Column="1" Margin="0,8" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="220" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardContainer}" Margin="20,0,20,20" Padding="14" BorderBrush="#E5EAF1">
            <WrapPanel HorizontalAlignment="Right" FlowDirection="LeftToRight">
                <Button x:Name="CancelButton" MinWidth="140" Style="{StaticResource GhostButton}" Margin="12,0,0,8" Click="OnCancel" ToolTip="{DynamicResource TooltipCancel}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloseCircleOutline" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource BtnClear}" />
                    </StackPanel>
                </Button>
                <Button x:Name="SaveButton" MinWidth="150" Style="{StaticResource PrimaryButton}" Click="OnSave" ToolTip="{DynamicResource TooltipSave}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource BtnApply}" />
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>
    </Grid>
</Window>
