<Window x:Class="GoldShopWpf.Views.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="تفعيل البرنامج"
        Width="720"
        Height="620"
        MinWidth="680"
        MinHeight="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FlowDirection="{DynamicResource AppFlowDirection}">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Border Style="{StaticResource CardContainer}"
                Margin="24"
                Background="#FFFDFC"
                BorderBrush="#E7ECF2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="0,0,0,20"
                        Padding="24"
                        CornerRadius="22"
                        Background="#FFF9EC"
                        BorderBrush="#F1E0A9"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="تفعيل البرنامج" FontSize="26" FontWeight="Bold" />
                            <TextBlock Text="هذا الإصدار محمي برقم جهاز ومفتاح ترخيص. انسخ معرف الجهاز ثم أنشئ المفتاح والصقه هنا." Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Text="Licensed to: Abo Emad" Margin="0,10,0,0" FontWeight="SemiBold" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="58"
                                Height="58"
                                CornerRadius="18"
                                Background="#FFE29A">
                            <materialDesign:PackIcon Kind="ShieldKeyOutline"
                                                     Width="28"
                                                     Height="28"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="معرف الجهاز" Style="{StaticResource FieldLabelText}" />
                    <TextBox x:Name="MachineIdTextBox"
                             IsReadOnly="True"
                             Margin="0,0,0,12"
                             FontWeight="SemiBold" />

                    <Button Style="{StaticResource GhostButton}"
                            Width="150"
                            HorizontalAlignment="Right"
                            Click="OnCopyMachineId"
                            Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentCopy" Margin="0,0,6,0" />
                            <TextBlock Text="نسخ معرف الجهاز" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="مفتاح الترخيص" Style="{StaticResource FieldLabelText}" />
                    <TextBox x:Name="LicenseKeyTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="170"
                             Padding="14"
                             materialDesign:HintAssist.Hint="الصق مفتاح الترخيص هنا" />

                    <Border Margin="0,18,0,0"
                            Padding="16"
                            CornerRadius="16"
                            Background="#F8FAFC"
                            BorderBrush="#DFE7F2"
                            BorderThickness="1">
                        <TextBlock Text="خطوات التفعيل: 1) انسخ معرف الجهاز. 2) أنشئ المفتاح من أداة الترخيص. 3) الصق المفتاح واضغط تفعيل." Foreground="{StaticResource MutedTextBrush}" />
                    </Border>
                </StackPanel>

                <Border Grid.Row="2"
                        Margin="0,24,0,0"
                        Padding="18"
                        CornerRadius="18"
                        Background="#FFFFFF"
                        BorderBrush="#E7ECF2"
                        BorderThickness="1">
                    <WrapPanel HorizontalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}"
                                Width="150"
                                Margin="0,0,12,0"
                                Click="OnClose">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CloseCircleOutline" Margin="0,0,6,0" />
                                <TextBlock Text="إغلاق" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource PrimaryButton}"
                                Width="170"
                                Click="OnActivate">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="KeyVariant" Margin="0,0,6,0" />
                                <TextBlock Text="تفعيل" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
