<Window x:Class="GoldShopWpf.Views.DiscountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource WindowAddDiscount}"
        Height="520"
        Width="700"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FlowDirection="{DynamicResource AppFlowDirection}">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="20,20,20,0"
                Padding="24"
                CornerRadius="24"
                Background="#FFF7F1"
                BorderBrush="#F2DDD2"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Border Width="54" Height="54" CornerRadius="16" Background="#FFE0CC">
                    <materialDesign:PackIcon Kind="PercentCircle" Width="24" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0">
                    <TextBlock Text="{DynamicResource WindowAddDiscount}" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="{DynamicResource SubDiscountWindow}" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardContainer}" Margin="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{DynamicResource LblDiscountType}" Grid.Row="0" Grid.Column="0" Margin="8,12" />
                    <ComboBox x:Name="TypeCombo" Grid.Row="0" Grid.Column="1" DisplayMemberPath="Label" SelectedValuePath="Type" Margin="0,8" />

                    <TextBlock Text="{DynamicResource LblAmount}" Grid.Row="1" Grid.Column="0" Margin="8,12" />
                    <TextBox x:Name="AmountText" Grid.Row="1" Grid.Column="1" Margin="0,8" />

                    <TextBlock Text="{DynamicResource LblNotes}" Grid.Row="2" Grid.Column="0" Margin="8,12" VerticalAlignment="Top" />
                    <TextBox x:Name="NotesText" Grid.Row="2" Grid.Column="1" Margin="0,8" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="160" VerticalScrollBarVisibility="Auto" />

                    <StackPanel Orientation="Horizontal" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Width="140" Style="{StaticResource GhostButton}" Margin="12,0,0,0" Click="OnCancel" ToolTip="{DynamicResource TooltipCancel}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CloseCircleOutline" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnClear}" />
                            </StackPanel>
                        </Button>
                        <Button Width="150" Style="{StaticResource PrimaryButton}" Click="OnSave" ToolTip="{DynamicResource TooltipSave}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnApply}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
