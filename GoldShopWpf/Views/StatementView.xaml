<UserControl x:Class="GoldShopWpf.Views.StatementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="ReceiptGridHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="TextBlock.TextWrapping" Value="Wrap" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">
            <Border Margin="0,0,0,18"
                    Padding="28"
                    CornerRadius="28"
                    BorderBrush="#E8E3DA"
                    BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFDF8" Offset="0" />
                        <GradientStop Color="#F8F1E3" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource NavStatement}" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="{DynamicResource LblStatementSub}"
                                   FontSize="15"
                                   Foreground="#6B5B2A"
                                   Margin="0,0,0,18" />
                        <WrapPanel>
                            <StackPanel MinWidth="220" Margin="0,0,16,8">
                                <TextBlock Text="{DynamicResource LblSupplier}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                <ComboBox Style="{StaticResource SearchableTraderComboBox}" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="Name" Margin="0" />
                            </StackPanel>
                            <StackPanel MinWidth="180" Margin="0,0,16,8">
                                <TextBlock Text="{DynamicResource LblFrom}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                <DatePicker SelectedDate="{Binding FromDate}" Margin="0" />
                            </StackPanel>
                            <StackPanel MinWidth="180" Margin="0,0,16,8">
                                <TextBlock Text="{DynamicResource LblTo}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                                <DatePicker SelectedDate="{Binding ToDate}" Margin="0" />
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>

                    <WrapPanel Grid.Column="1" VerticalAlignment="Top">
                        <Button Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Command="{Binding GenerateCommand}" ToolTip="{DynamicResource BtnUpdateDates}" MinWidth="136">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnUpdateDates}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButton}" Command="{Binding PrintCommand}" ToolTip="{DynamicResource BtnPrint}" MinWidth="118">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Printer" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnPrint}" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardContainer}"
                    MaxWidth="860"
                    HorizontalAlignment="Center"
                    BorderBrush="#E7ECF2"
                    Background="#FFFDFC">
                <StackPanel>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{DynamicResource ReceiptTitle}" FontSize="28" FontWeight="Bold" />
                            <TextBlock Text="{Binding SupplierNameDisplay}" Margin="0,6,0,0" FontSize="16" FontWeight="SemiBold" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LblDate}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding CurrentDateDisplay}" FontSize="15" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Background="#FFF7E2"
                            BorderBrush="#F0DFA7"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="16,12"
                            Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource ReceiptDateRange}" FontWeight="SemiBold" Foreground="#8A6C00" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding FromDate, StringFormat={}{0:yyyy/MM/dd}}"
                                       FontWeight="SemiBold"
                                       Foreground="#8A6C00" />
                            <TextBlock Grid.Column="1"
                                       Margin="120,0,0,0"
                                       Text="{Binding ToDate, StringFormat={}{0:yyyy/MM/dd}}"
                                       Foreground="#8A6C00" />
                        </Grid>
                    </Border>

                    <TextBlock Text="{DynamicResource ReceiptTransactionTable}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <DataGrid ItemsSource="{Binding Rows}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ColumnHeaderStyle="{StaticResource ReceiptGridHeaderStyle}"
                              Margin="0,0,0,18">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource LblDate}" Binding="{Binding Date, StringFormat={}{0:yyyy/MM/dd}}" Width="1.15*" MinWidth="108" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblType}" Binding="{Binding Type}" Width="1.35*" MinWidth="118" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblItem}" Binding="{Binding Item}" Width="1.45*" MinWidth="130" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblEquivalent21}" Binding="{Binding Weight, StringFormat={}{0:0.####}}" Width="1.1*" MinWidth="118" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblTotalManufacturing}" Binding="{Binding Manufacturing, StringFormat={}{0:0.##}}" Width="1.2*" MinWidth="132" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblTotalImprovement}" Binding="{Binding Improvement, StringFormat={}{0:0.##}}" Width="1.2*" MinWidth="128" ElementStyle="{StaticResource GridCellTextStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Background="#FFFCF5"
                            BorderBrush="#E9DFC9"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource ReceiptSummary}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource LblTotalGoldReport}" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding TotalGoldDisplay}" FontWeight="SemiBold" />
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource LblTotalManufacturingReport}" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding TotalManufacturingDisplay}" FontWeight="SemiBold" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource LblTotalImprovement}" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding TotalImprovementDisplay}" FontWeight="SemiBold" />
                            </Grid>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource LblNetTotalReport}" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="{Binding NetTotalDisplay}" FontWeight="Bold" FontSize="18" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
