<UserControl x:Class="GoldShopWpf.Views.StatementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardContainer}" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource LblSupplier}" VerticalAlignment="Center" Margin="5" />
                <ComboBox Grid.Column="1" Width="220" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="Name" Margin="5" />
                <TextBlock Grid.Column="2" Text="{DynamicResource LblFrom}" VerticalAlignment="Center" Margin="5" />
                <DatePicker Grid.Column="3" SelectedDate="{Binding FromDate}" Width="140" Margin="5"
                            materialDesign:HintAssist.Hint="من" />
                <TextBlock Grid.Column="4" Text="{DynamicResource LblTo}" VerticalAlignment="Center" Margin="5" />
                <DatePicker Grid.Column="5" SelectedDate="{Binding ToDate}" Width="140" Margin="5"
                            materialDesign:HintAssist.Hint="إلى" />
                <Button Grid.Column="6" Style="{StaticResource PrimaryButton}" Margin="5" Command="{Binding GenerateCommand}" ToolTip="{DynamicResource BtnApply}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocumentOutline" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource BtnApply}" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="7" Style="{StaticResource GhostButton}" Margin="5" Command="{Binding PrintCommand}" ToolTip="{DynamicResource BtnPrint}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Printer" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource BtnPrint}" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Style="{StaticResource CardContainer}" Grid.Row="1">
            <TextBox Text="{Binding StatementText}" IsReadOnly="True" TextWrapping="NoWrap" FontFamily="{DynamicResource AppFontFamily}" FontSize="12"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
        </Border>
    </Grid>
</UserControl>


