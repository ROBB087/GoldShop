<UserControl x:Class="GoldShopWpf.Views.TransactionsView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FlowDirection="{DynamicResource AppFlowDirection}">
    <UserControl.Resources>
        <Style x:Key="GridActionMenu" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FlowDirection" Value="LeftToRight" />
        </Style>

        <Style x:Key="GridActionMenuItem" TargetType="MenuItem">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="TransactionTypeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource GridCellTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#2457C5" />
        </Style>

    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardContainer}" Margin="0,0,0,12" Padding="24" BorderBrush="#C9D5E6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F5F8FC" Offset="0" />
                    <GradientStop Color="#E8F0FB" Offset="0.55" />
                    <GradientStop Color="#F2F7FF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="48"
                        Height="48"
                        Background="#EEF4FF"
                        BorderBrush="#D6E4FF"
                        BorderThickness="1"
                        CornerRadius="16"
                        VerticalAlignment="Top">
                    <materialDesign:PackIcon Kind="SwapHorizontalBold"
                                             Width="22"
                                             Height="22"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Foreground="#2457C5" />
                </Border>
                <StackPanel Grid.Column="2" HorizontalAlignment="Left">
                    <TextBlock Text="{DynamicResource NavTransactions}" FontSize="24" FontWeight="SemiBold" Foreground="#0F172A" />
                    <TextBlock Text="{DynamicResource LblTransactionsSub}" FontSize="13" Foreground="#475467" Margin="0,4,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="3" HorizontalAlignment="Right">
                    <Button Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Height="46" MinWidth="168" Padding="18,10" Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource BtnAddTransaction}" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardContainer}" Margin="0,0,0,12" Padding="14" BorderBrush="#E4E8F1">
            <WrapPanel>
                    <StackPanel MinWidth="220" Margin="0,0,12,8">
                        <TextBlock Text="{DynamicResource LblTrader}" Margin="0,0,0,4" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <ComboBox Style="{StaticResource SearchableTraderComboBox}" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="Name" />
                    </StackPanel>
                    <StackPanel MinWidth="180" Margin="0,0,12,8">
                        <TextBlock Text="{DynamicResource LblFrom}" Margin="0,0,0,4" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <DatePicker SelectedDate="{Binding FromDate}" />
                    </StackPanel>
                    <StackPanel MinWidth="180" Margin="0,0,12,8">
                        <TextBlock Text="{DynamicResource LblTo}" Margin="0,0,0,4" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <DatePicker SelectedDate="{Binding ToDate}" />
                    </StackPanel>
                <Button Command="{Binding ResetFiltersCommand}" Style="{StaticResource CompactToolbarButton}" MinWidth="92" Margin="0,22,0,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterRemoveOutline" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource BtnReset}" />
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,12" />

        <Border Grid.Row="3" Style="{StaticResource CardContainer}" Padding="0" BorderBrush="#E5EAF1">
            <Grid IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CompactCommandBar}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <WrapPanel>
                            <Button Command="{Binding AddCommand}" Style="{StaticResource CompactPrimaryToolbarButton}" MinWidth="132" Height="38">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Margin="0,0,6,0" />
                                    <TextBlock Text="{DynamicResource BtnAdd}" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                        <Menu Grid.Column="1" Style="{StaticResource GridActionMenu}">
                            <MenuItem Header="{DynamicResource BtnMore}" Style="{StaticResource GridActionMenuItem}">
                                <MenuItem Header="{DynamicResource BtnEdit}" Command="{Binding EditCommand}" />
                                <MenuItem Header="{DynamicResource BtnDelete}" Command="{Binding DeleteCommand}" />
                                <MenuItem Header="{DynamicResource BtnClearSelection}" Command="{Binding ClearSelectionCommand}" />
                                <Separator />
                                <MenuItem Header="{DynamicResource BtnRefresh}" Command="{Binding RefreshCommand}" />
                            </MenuItem>
                        </Menu>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredTransactions}"
                          SelectedItem="{Binding SelectedTransaction}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserSortColumns="True"
                          IsReadOnly="True"
                          FrozenColumnCount="1"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="56" CanUserSort="False">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <CheckBox IsThreeState="False"
                                              IsChecked="{Binding DataContext.AreAllVisibleSelected, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=OneWay}"
                                              Click="OnSelectAllClicked"
                                              ToolTip="{DynamicResource LblSelectAllRecords}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="{DynamicResource LblTrader}" Width="1.6*" MinWidth="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SupplierName}"
                                               Style="{StaticResource GridCellTextStyle}"
                                               FontWeight="Bold" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="{DynamicResource LblType}" Width="1.2*" MinWidth="96">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock x:Name="TransactionTypeText"
                                               Text="{Binding Category, Converter={StaticResource TransactionCategoryToLabelConverter}}"
                                               Style="{StaticResource TransactionTypeTextStyle}" />
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Category}" Value="GoldOutbound">
                                            <Setter TargetName="TransactionTypeText" Property="Foreground" Value="#B42318" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Category}" Value="GoldReceipt">
                                            <Setter TargetName="TransactionTypeText" Property="Foreground" Value="#067647" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Category}" Value="CashPayment">
                                            <Setter TargetName="TransactionTypeText" Property="Foreground" Value="#B54708" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource LblWeight}" Binding="{Binding OriginalWeight, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}" Width="*" MinWidth="78" ElementStyle="{StaticResource GridCellTextStyle}" />
                        <DataGridTextColumn Header="{DynamicResource LblKarat}" Binding="{Binding OriginalKarat}" Width="0.8*" MinWidth="60" ElementStyle="{StaticResource GridCellTextStyle}" />
                        <DataGridTextColumn Header="{DynamicResource LblEquivalent21}" Binding="{Binding Equivalent21, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}" Width="*" MinWidth="92" ElementStyle="{StaticResource GridCellTextStyle}" />
                        <DataGridTextColumn Header="{DynamicResource LblItem}" Binding="{Binding ItemName}" Width="1.2*" MinWidth="110" ElementStyle="{StaticResource GridCellTextStyle}" />
                        <DataGridTextColumn Header="{DynamicResource LblNotes}" Binding="{Binding Notes}" Width="1.4*" MinWidth="140" ElementStyle="{StaticResource GridCellTextStyle}" />
                        <DataGridTextColumn Header="{DynamicResource LblCreatedAt}" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy/MM/dd HH:mm}}" Width="1.3*" MinWidth="140" ElementStyle="{StaticResource GridCellTextStyle}" />
                        <DataGridTextColumn Header="{DynamicResource LblLastUpdated}" Binding="{Binding UpdatedAt, StringFormat={}{0:yyyy/MM/dd HH:mm}}" Width="1.3*" MinWidth="140" ElementStyle="{StaticResource GridCellTextStyle}" />
                        <DataGridTemplateColumn Header="..." Width="86">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Menu Style="{StaticResource GridActionMenu}" HorizontalAlignment="Center">
                                        <MenuItem Header="{DynamicResource BtnMore}" Style="{StaticResource GridActionMenuItem}">
                                            <MenuItem Header="{DynamicResource BtnViewDetails}" Command="{Binding DataContext.ViewRowCommand, Source={x:Reference Root}}" CommandParameter="{Binding}" />
                                            <MenuItem Header="{DynamicResource BtnEdit}" Command="{Binding DataContext.EditRowCommand, Source={x:Reference Root}}" CommandParameter="{Binding}" />
                                            <MenuItem Header="{DynamicResource BtnDelete}" Command="{Binding DataContext.DeleteRowCommand, Source={x:Reference Root}}" CommandParameter="{Binding}" />
                                        </MenuItem>
                                    </Menu>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1" Background="#F8FAFC"
                        Visibility="{Binding FilteredTransactions.Count, Converter={StaticResource ZeroCountToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="DatabaseSearchOutline" Width="42" Height="42" Foreground="#98A2B3" HorizontalAlignment="Center" />
                        <TextBlock Text="{DynamicResource LblEmptyTransactionsTitle}" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,6" HorizontalAlignment="Center" />
                        <TextBlock Text="{DynamicResource LblEmptyTransactionsSub}" Foreground="#667085" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1,1,1,0" Padding="10,8">
                    <WrapPanel>
                        <Border Padding="12,8" Background="#FFFFFF" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="12" Margin="0,0,12,8">
                            <TextBlock Text="{Binding RowsCountLabel}" FontWeight="SemiBold" Foreground="#344054" />
                        </Border>
                        <Border Padding="12,8" Background="#FFFFFF" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="12" Margin="0,0,8,8">
                            <TextBlock Text="{Binding PageSummary}" FontWeight="SemiBold" Foreground="#344054" />
                        </Border>
                        <Border Padding="12,8" Background="#FFF7E2" BorderBrush="#F0DFA7" BorderThickness="1" CornerRadius="12" Margin="0,0,12,8">
                            <TextBlock Text="{Binding SelectedCountLabel}" FontWeight="SemiBold" Foreground="#8A6C00" />
                        </Border>
                        <WrapPanel>
                            <Button Command="{Binding PreviousPageCommand}" Style="{StaticResource CompactToolbarButton}" MinWidth="74" Margin="0,0,8,8">
                                <TextBlock Text="{DynamicResource BtnPreviousPage}" />
                            </Button>
                            <Button Command="{Binding NextPageCommand}" Style="{StaticResource CompactToolbarButton}" MinWidth="74" Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource BtnNextPage}" />
                            </Button>
                        </WrapPanel>
                    </WrapPanel>
                </Border>

                <Border Grid.RowSpan="3" Visibility="{Binding IsBusyVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#B3FFFFFF">
                    <Border Style="{StaticResource LoadingOverlayCard}">
                        <StackPanel>
                            <ProgressBar IsIndeterminate="True" Width="180" Height="6" Margin="0,0,0,14" />
                            <TextBlock Text="{Binding BusyMessage}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
