<Window x:Class="GoldShopWpf.Views.OpeningBalanceAdjustmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{DynamicResource WindowAddOpeningBalanceAdjustment}"
        Height="760"
        Width="580"
        MinWidth="500"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FlowDirection="{DynamicResource AppFlowDirection}">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="20,20,20,0"
                Padding="24"
                CornerRadius="24"
                Background="#F2F7FF"
                BorderBrush="#D6E4FF"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Border Width="54" Height="54" CornerRadius="16" Background="#E1ECFF">
                    <materialDesign:PackIcon Kind="CalculatorVariantOutline" Width="24" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0">
                    <TextBlock x:Name="HeaderTitleText" Text="{DynamicResource WindowAddOpeningBalanceAdjustment}" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="{DynamicResource SubOpeningBalanceAdjustmentWindow}" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardContainer}" Margin="20,20,20,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{DynamicResource LblOpeningBalanceAdjustmentType}" Grid.Row="0" Grid.Column="0" Margin="8,12" />
                    <ComboBox x:Name="TypeCombo" Grid.Row="0" Grid.Column="1" DisplayMemberPath="Label" SelectedValuePath="Type" Margin="0,8" />

                    <TextBlock Text="{DynamicResource LblDate}" Grid.Row="1" Grid.Column="0" Margin="8,12" />
                    <DatePicker x:Name="AdjustmentDatePicker" Grid.Row="1" Grid.Column="1" Margin="0,8" />

                    <TextBlock Text="{DynamicResource LblAmount}" Grid.Row="2" Grid.Column="0" Margin="8,12" />
                    <TextBox x:Name="AmountText" Grid.Row="2" Grid.Column="1" Margin="0,8" />

                    <TextBlock Text="{DynamicResource LblNotes}" Grid.Row="3" Grid.Column="0" Margin="8,12" VerticalAlignment="Top" />
                    <TextBox x:Name="NotesText" Grid.Row="3" Grid.Column="1" Margin="0,8" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="160" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardContainer}" Margin="20,0,20,20" Padding="14" BorderBrush="#E5EAF1">
            <WrapPanel HorizontalAlignment="Right" FlowDirection="LeftToRight">
                <Button MinWidth="140" Style="{StaticResource GhostButton}" Margin="12,0,0,8" Click="OnCancel" ToolTip="{DynamicResource TooltipCancel}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloseCircleOutline" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource BtnClear}" />
                    </StackPanel>
                </Button>
                <Button MinWidth="150" Style="{StaticResource PrimaryButton}" Click="OnSave" ToolTip="{DynamicResource TooltipSave}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource BtnApply}" />
                    </StackPanel>
                </Button>
            </WrapPanel>
        </Border>
    </Grid>
</Window>
