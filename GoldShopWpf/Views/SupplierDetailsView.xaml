<UserControl x:Class="GoldShopWpf.Views.SupplierDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource CardContainer}"
                    Margin="0,0,0,12"
                    Background="#FCFBF7"
                    BorderBrush="#EEE6D6">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Padding="12,8"
                                CornerRadius="14"
                                Background="#FFF6DD"
                                BorderBrush="#F0E1AF"
                                BorderThickness="1">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#6A5600">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Transactions.Count, StringFormat=Transactions: {0}}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=FlowDirection}" Value="RightToLeft">
                                                <Setter Property="Text" Value="{Binding Transactions.Count, StringFormat=الحركات: {0}}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <Border Grid.Column="1"
                                Margin="16,0,0,0"
                                Background="#FFFFFF"
                                BorderBrush="#E4E8F0"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="14,10"
                                HorizontalAlignment="Left"
                                Width="360">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox Width="290"
                                         Margin="0"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{DynamicResource LblSearch}"
                                         materialDesign:HintAssist.Hint="{DynamicResource LblSearch}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <WrapPanel Grid.Row="1"
                               Margin="8,0,8,8"
                               Orientation="Horizontal">
                        <StackPanel Width="320" Margin="0,0,16,0">
                            <TextBlock Text="{DynamicResource LblTrader}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,0,0,6" />
                            <ComboBox Margin="0"
                                      ItemsSource="{Binding SupplierOptions}"
                                      SelectedItem="{Binding SelectedTrader, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberPath="Name" />
                        </StackPanel>

                        <StackPanel Width="220" Margin="0,0,16,0">
                            <TextBlock Text="{DynamicResource LblFrom}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,0,0,6" />
                            <DatePicker Margin="0"
                                        SelectedDate="{Binding FromDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Width="220" Margin="0,0,16,0">
                            <TextBlock Text="{DynamicResource LblTo}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,0,0,6" />
                            <DatePicker Margin="0"
                                        SelectedDate="{Binding ToDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Width="132" Margin="0,18,12,0">
                            <Button MinWidth="132"
                                    MinHeight="48"
                                    Content="{DynamicResource LblSearch}"
                                    Command="{Binding ApplyFilterCommand}"
                                    Style="{StaticResource GhostButton}" />
                        </StackPanel>

                        <StackPanel Width="132" Margin="0,18,0,0">
                            <Button MinWidth="132"
                                    MinHeight="48"
                                    Content="{DynamicResource BtnReset}"
                                    Command="{Binding ClearFilterCommand}"
                                    Style="{StaticResource GhostButton}" />
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel Grid.Row="2"
                               Margin="0,8,0,0"
                               Orientation="Horizontal">
                        <Button Command="{Binding AddTransactionCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="8"
                                MinWidth="172"
                                MinHeight="48">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnAddTransaction}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding AddDiscountCommand}"
                                Style="{StaticResource GhostButton}"
                                Margin="8"
                                MinWidth="150"
                                MinHeight="48">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Percent" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnAddDiscount}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding EditTransactionCommand}"
                                Style="{StaticResource GhostButton}"
                                Margin="8"
                                MinWidth="124"
                                MinHeight="48">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnEdit}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding DeleteTransactionCommand}"
                                Style="{StaticResource GhostButton}"
                                Margin="8"
                                MinWidth="124"
                                MinHeight="48">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Margin="0,0,6,0" Foreground="#D32F2F" />
                                <TextBlock Text="{DynamicResource BtnDelete}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding PrintStatementCommand}"
                                Style="{StaticResource GhostButton}"
                                Margin="8"
                                MinWidth="190"
                                MinHeight="48">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Printer" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource NavStatement}" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource CardContainer}"
                    Margin="0,0,0,12"
                    Background="#FFFFFF"
                    BorderBrush="#ECE8DD">
                <Grid Margin="4,0,4,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="8"
                            Padding="18"
                            Background="#F9FAFB"
                            CornerRadius="18"
                            BorderBrush="#E7ECF2"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LblGoldPosition}" FontSize="13" FontWeight="SemiBold" Foreground="#667085" Margin="0,0,0,16" />
                            <materialDesign:Card Padding="18" Background="#FFFFFF">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LblTotalGold21}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,8" />
                                    <TextBlock Text="{Binding TotalGold21, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}" FontSize="28" FontWeight="Bold" />
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Margin="8"
                            Padding="18"
                            Background="#F9FAFB"
                            CornerRadius="18"
                            BorderBrush="#E7ECF2"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LblCurrentCharges}" FontSize="13" FontWeight="SemiBold" Foreground="#667085" Margin="0,0,0,16" />
                            <WrapPanel>
                                <materialDesign:Card Width="220" Padding="18" Margin="0,0,12,0" Background="#FFFFFF">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LblTotalManufacturing}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding FinalManufacturing, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}" FontSize="28" FontWeight="Bold" />
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Width="220" Padding="18" Background="#FFFFFF">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LblTotalImprovement}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding FinalImprovement, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}" FontSize="28" FontWeight="Bold" />
                                    </StackPanel>
                                </materialDesign:Card>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Margin="8"
                            Padding="18"
                            Background="#FFF8F4"
                            CornerRadius="18"
                            BorderBrush="#F2DDD2"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LblAppliedDiscounts}" FontSize="13" FontWeight="SemiBold" Foreground="#9A3412" Margin="0,0,0,16" />
                            <WrapPanel>
                                <materialDesign:Card Width="220" Padding="18" Margin="0,0,12,0" Background="#FFFFFF">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LblManufacturingDiscounts}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding ManufacturingDiscounts, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}" FontSize="28" FontWeight="Bold" Foreground="#C62828" />
                                    </StackPanel>
                                </materialDesign:Card>
                                <materialDesign:Card Width="220" Padding="18" Background="#FFFFFF">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource LblImprovementDiscounts}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding ImprovementDiscounts, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}" FontSize="28" FontWeight="Bold" Foreground="#C62828" />
                                    </StackPanel>
                                </materialDesign:Card>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource CardContainer}"
                    Margin="0,0,0,12"
                    BorderBrush="#E7ECF2">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{DynamicResource NavTransactions}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="8" />

                    <DataGrid Grid.Row="1"
                              Margin="8"
                              Height="340"
                              ItemsSource="{Binding Transactions}"
                              SelectedItem="{Binding SelectedTransaction, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource LblDate}" Binding="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" Width="140" MinWidth="140" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblTrader}" Binding="{Binding SupplierName}" Width="*" MinWidth="180" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblType}" Binding="{Binding Category, Converter={StaticResource TransactionCategoryToLabelConverter}}" Width="160" MinWidth="150" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblWeight}" Binding="{Binding OriginalWeight, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}" Width="130" MinWidth="130" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblKarat}" Binding="{Binding OriginalKarat}" Width="100" MinWidth="100" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblEquivalent21}" Binding="{Binding Equivalent21, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}" Width="150" MinWidth="150" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblTotalManufacturing}" Binding="{Binding TotalManufacturing, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}" Width="170" MinWidth="170" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblTotalImprovement}" Binding="{Binding TotalImprovement, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}" Width="170" MinWidth="170" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblNotes}" Binding="{Binding Notes}" Width="2*" MinWidth="240" ElementStyle="{StaticResource GridCellTextStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Style="{StaticResource CardContainer}"
                    BorderBrush="#E7ECF2">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{DynamicResource LblDiscounts}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="8" />

                    <DataGrid Grid.Row="1"
                              Margin="8"
                              Height="240"
                              ItemsSource="{Binding Discounts}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource LblDate}" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd}}" Width="140" MinWidth="140" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblTrader}" Binding="{Binding SupplierName}" Width="*" MinWidth="180" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblType}" Binding="{Binding Type}" Width="180" MinWidth="170" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblAmount}" Binding="{Binding Amount, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}" Width="170" MinWidth="170" ElementStyle="{StaticResource GridCellTextStyle}" />
                            <DataGridTextColumn Header="{DynamicResource LblNotes}" Binding="{Binding Notes}" Width="*" MinWidth="240" ElementStyle="{StaticResource GridCellTextStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
