<UserControl x:Class="GoldShopWpf.Views.SupplierDetailsView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FlowDirection="{DynamicResource AppFlowDirection}">
    <UserControl.Resources>
        <Style x:Key="GridActionMenu" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FlowDirection" Value="LeftToRight" />
        </Style>

        <Style x:Key="GridActionMenuItem" TargetType="MenuItem">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="CenterMetricCard" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D9E2F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="108" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                        <TranslateTransform Y="0" />
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.18" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.18" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" To="-2" Duration="0:0:0.18" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.18" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.18" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" To="0" Duration="0:0:0.18" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TypeBadgeBorder" TargetType="Border">
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="#EEF4FF" />
            <Setter Property="BorderBrush" Value="#D6E4FF" />
        </Style>

        <Style x:Key="TypeBadgeText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#2457C5" />
        </Style>

        <Style x:Key="TransactionTypeTextOnlyStyle" TargetType="TextBlock" BasedOn="{StaticResource GridCellTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#2457C5" />
        </Style>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardContainer}" Padding="24" BorderBrush="#C9D5E6" Margin="0,0,0,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F5F8FC" Offset="0" />
                    <GradientStop Color="#E8F0FB" Offset="0.55" />
                    <GradientStop Color="#F2F7FF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="48"
                        Height="48"
                        Background="#EEF4FF"
                        BorderBrush="#D6E4FF"
                        BorderThickness="1"
                        CornerRadius="16"
                        VerticalAlignment="Top">
                    <materialDesign:PackIcon Kind="AccountDetails"
                                             Width="22"
                                             Height="22"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Foreground="#2457C5" />
                </Border>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding SupplierDisplayName}" FontSize="24" FontWeight="SemiBold" Foreground="#0F172A" />
                    <TextBlock Text="{DynamicResource LblTraderDetailsSub}" FontSize="13" Foreground="#475467" Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Column="3" Command="{Binding AddTransactionCommand}" Style="{StaticResource PrimaryButton}" Height="46" MinWidth="168" Padding="18,10">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Margin="0,0,6,0" />
                        <TextBlock Text="{DynamicResource BtnAddTransaction}" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardContainer}" Padding="14" BorderBrush="#E4E8F1" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource LblTrader}" Margin="0,0,0,4" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <ComboBox Style="{StaticResource SearchableTraderComboBox}" ItemsSource="{Binding SupplierOptions}" SelectedItem="{Binding SelectedTrader}" DisplayMemberPath="Name" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource LblFrom}" Margin="0,0,0,4" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <DatePicker SelectedDate="{Binding FromDate}" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="{DynamicResource LblTo}" Margin="0,0,0,4" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                        <DatePicker SelectedDate="{Binding ToDate}" />
                    </StackPanel>
                </Grid>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Command="{Binding ApplyFilterCommand}" Style="{StaticResource CompactPrimaryToolbarButton}">
                        <TextBlock Text="{DynamicResource BtnRefresh}" />
                    </Button>
                    <Button Command="{Binding ClearFilterCommand}" Style="{StaticResource CompactToolbarButton}" Margin="0">
                        <TextBlock Text="{DynamicResource BtnReset}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CenterMetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Width="42" Height="42" CornerRadius="14" Background="#EEF4FF" BorderBrush="#D6E4FF" BorderThickness="1" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Gold" Width="20" Height="20" Foreground="#2457C5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LblTotalGold21}" Foreground="#667085" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TotalGold21, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}" FontSize="20" FontWeight="Bold" Foreground="#101828" Margin="0,6,0,0" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Viewbox>
                </Grid>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CenterMetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Width="42" Height="42" CornerRadius="14" Background="#FDF2FA" BorderBrush="#F4D5EA" BorderThickness="1" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Factory" Width="20" Height="20" Foreground="#C11574" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LblFinalManufacturing}" Foreground="#667085" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding FinalManufacturing, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}" FontSize="20" FontWeight="Bold" Foreground="#101828" Margin="0,6,0,0" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Viewbox>
                </Grid>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource CenterMetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Width="42" Height="42" CornerRadius="14" Background="#ECFDF3" BorderBrush="#ABEFC6" BorderThickness="1" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="TrendingUp" Width="20" Height="20" Foreground="#067647" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LblFinalImprovement}" Foreground="#667085" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding FinalImprovement, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}" FontSize="20" FontWeight="Bold" Foreground="#101828" Margin="0,6,0,0" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Viewbox>
                </Grid>
            </Border>
            <Border Grid.Column="6" Style="{StaticResource CenterMetricCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Width="42" Height="42" CornerRadius="14" Background="#FFF7E2" BorderBrush="#F0DFA7" BorderThickness="1" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="PercentBoxOutline" Width="20" Height="20" Foreground="#B54708" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LblDiscounts}" Foreground="#8A6C00" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TotalDiscounts, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}" FontSize="20" FontWeight="Bold" Foreground="#B54708" Margin="0,6,0,0" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource CardContainer}" Padding="0" BorderBrush="#E5EAF1" Margin="0,0,0,12">
            <Grid>
                <TabControl BorderThickness="0" Background="Transparent" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                <TabItem Header="{DynamicResource LblTransactionsTab}">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource CompactCommandBar}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <WrapPanel>
                                    <Button Command="{Binding AddTransactionCommand}" Style="{StaticResource CompactPrimaryToolbarButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Margin="0,0,6,0" />
                                            <TextBlock Text="{DynamicResource BtnAdd}" />
                                        </StackPanel>
                                    </Button>
                                    </WrapPanel>
                                    <Menu Grid.Column="1" Style="{StaticResource GridActionMenu}">
                                        <MenuItem Header="{DynamicResource BtnMore}" Style="{StaticResource GridActionMenuItem}">
                                            <MenuItem Header="{DynamicResource BtnEdit}" Command="{Binding EditTransactionCommand}" />
                                            <MenuItem Header="{DynamicResource BtnDelete}" Command="{Binding DeleteTransactionCommand}" />
                                            <MenuItem Header="{DynamicResource BtnClearSelection}" Command="{Binding ClearTransactionSelectionCommand}" />
                                            <Separator />
                                            <MenuItem Header="{DynamicResource BtnRefresh}" Command="{Binding RefreshCommand}" />
                                        </MenuItem>
                                    </Menu>
                                </Grid>
                            </Border>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Transactions}" SelectedItem="{Binding SelectedTransaction}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Extended" SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="56" CanUserSort="False">
                                        <DataGridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <CheckBox IsThreeState="False"
                                                          IsChecked="{Binding DataContext.AreAllVisibleTransactionsSelected, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=OneWay}"
                                                          Click="OnSelectAllTransactionsClicked"
                                                          ToolTip="{DynamicResource LblSelectAllRecords}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.HeaderTemplate>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="{DynamicResource LblDate}" Binding="{Binding Date, StringFormat={}{0:yyyy/MM/dd}}" Width="1.1*" MinWidth="110" ElementStyle="{StaticResource GridCellTextStyle}" />
                                    <DataGridTextColumn Header="{DynamicResource LblTrader}" Binding="{Binding SupplierName}" Width="1.7*" MinWidth="140" ElementStyle="{StaticResource GridCellTextStyle}" />
                                    <DataGridTemplateColumn Header="{DynamicResource LblType}" Width="1.5*" MinWidth="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock x:Name="TransactionTypeText"
                                                           Text="{Binding Category, Converter={StaticResource TransactionCategoryToLabelConverter}}"
                                                           Style="{StaticResource TransactionTypeTextOnlyStyle}" />
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Category}" Value="GoldOutbound">
                                                        <Setter TargetName="TransactionTypeText" Property="Foreground" Value="#B42318" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="GoldReceipt">
                                                        <Setter TargetName="TransactionTypeText" Property="Foreground" Value="#067647" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="CashPayment">
                                                        <Setter TargetName="TransactionTypeText" Property="Foreground" Value="#B54708" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="{DynamicResource LblWeight}" Binding="{Binding OriginalWeight, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}" Width="1.1*" MinWidth="95" ElementStyle="{StaticResource GridCellTextStyle}" />
                                    <DataGridTextColumn Header="{DynamicResource LblEquivalent21}" Binding="{Binding Equivalent21, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}" Width="1.2*" MinWidth="110" ElementStyle="{StaticResource GridCellTextStyle}" />
                                    <DataGridTextColumn Header="{DynamicResource LblKarat}" Binding="{Binding OriginalKarat}" Width="0.8*" MinWidth="70" ElementStyle="{StaticResource GridCellTextStyle}" />
                                    <DataGridTextColumn Header="{DynamicResource LblTotalManufacturing}" Binding="{Binding TotalManufacturing, Converter={StaticResource MoneyFormatConverter}}" Width="1.3*" MinWidth="120" ElementStyle="{StaticResource GridCellTextStyle}" />
                                    <DataGridTextColumn Header="{DynamicResource LblTotalImprovement}" Binding="{Binding TotalImprovement, Converter={StaticResource MoneyFormatConverter}}" Width="1.3*" MinWidth="120" ElementStyle="{StaticResource GridCellTextStyle}" />
                                    <DataGridTemplateColumn Header="..." Width="104">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Menu Style="{StaticResource GridActionMenu}" HorizontalAlignment="Center">
                                                    <MenuItem Header="{DynamicResource BtnMore}" Style="{StaticResource GridActionMenuItem}">
                                                        <MenuItem Header="{DynamicResource BtnViewDetails}" Command="{Binding DataContext.ViewTransactionRowCommand, Source={x:Reference Root}}" CommandParameter="{Binding}" />
                                                        <MenuItem Header="{DynamicResource BtnEdit}" Command="{Binding DataContext.EditTransactionRowCommand, Source={x:Reference Root}}" CommandParameter="{Binding}" />
                                                        <MenuItem Header="{DynamicResource BtnDelete}" Command="{Binding DataContext.DeleteTransactionRowCommand, Source={x:Reference Root}}" CommandParameter="{Binding}" />
                                                    </MenuItem>
                                                </Menu>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border Grid.Row="1" Background="#F8FAFC" Visibility="{Binding Transactions.Count, Converter={StaticResource ZeroCountToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="FileDocumentOutline" Width="42" Height="42" Foreground="#98A2B3" HorizontalAlignment="Center" />
                                    <TextBlock Text="{DynamicResource LblEmptyTransactionsTitle}" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,6" HorizontalAlignment="Center" />
                                    <TextBlock Text="{DynamicResource LblEmptyTraderTransactionsSub}" Foreground="#667085" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1,1,1,0" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Padding="12,8" Background="#FFFFFF" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="12" Margin="0,0,12,0" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding TransactionsRowsCountLabel}" FontWeight="SemiBold" Foreground="#344054" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Border Padding="12,8" Background="#FFFFFF" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="12" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding TransactionsPageSummary}" FontWeight="SemiBold" Foreground="#344054" />
                                        </Border>
                                        <Border Padding="12,8" Background="#FFF7E2" BorderBrush="#F0DFA7" BorderThickness="1" CornerRadius="12">
                                            <TextBlock Text="{Binding TransactionsSelectedCountLabel}" FontWeight="SemiBold" Foreground="#8A6C00" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Command="{Binding PreviousTransactionsPageCommand}" Style="{StaticResource CompactToolbarButton}" MinWidth="74" Margin="0,0,8,0">
                                            <TextBlock Text="{DynamicResource BtnPreviousPage}" />
                                        </Button>
                                        <Button Command="{Binding NextTransactionsPageCommand}" Style="{StaticResource CompactToolbarButton}" MinWidth="74" Margin="0">
                                            <TextBlock Text="{DynamicResource BtnNextPage}" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="{DynamicResource LblDiscountsTab}">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource CompactCommandBar}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <WrapPanel>
                                    <Button Command="{Binding AddDiscountCommand}" Style="{StaticResource CompactPrimaryToolbarButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Margin="0,0,6,0" />
                                            <TextBlock Text="{DynamicResource BtnAdd}" />
                                        </StackPanel>
                                    </Button>
                                    </WrapPanel>
                                    <Menu Grid.Column="1" Style="{StaticResource GridActionMenu}">
                                        <MenuItem Header="{DynamicResource BtnMore}" Style="{StaticResource GridActionMenuItem}">
                                            <MenuItem Header="{DynamicResource BtnEdit}" Command="{Binding EditDiscountCommand}" />
                                            <MenuItem Header="{DynamicResource BtnDelete}" Command="{Binding DeleteDiscountCommand}" />
                                            <MenuItem Header="{DynamicResource BtnClearSelection}" Command="{Binding ClearDiscountSelectionCommand}" />
                                            <Separator />
                                            <MenuItem Header="{DynamicResource BtnRefresh}" Command="{Binding RefreshCommand}" />
                                        </MenuItem>
                                    </Menu>
                                </Grid>
                            </Border>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Discounts}" SelectedItem="{Binding SelectedDiscount}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Extended" SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="56" CanUserSort="False">
                                        <DataGridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <CheckBox IsThreeState="False"
                                                          IsChecked="{Binding DataContext.AreAllVisibleDiscountsSelected, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=OneWay}"
                                                          Click="OnSelectAllDiscountsClicked"
                                                          ToolTip="{DynamicResource LblSelectAllRecords}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.HeaderTemplate>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="{DynamicResource LblDate}" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy/MM/dd HH:mm}}" Width="1.3*" MinWidth="140" ElementStyle="{StaticResource GridCellTextStyle}" />
                                    <DataGridTextColumn Header="{DynamicResource LblTrader}" Binding="{Binding SupplierName}" Width="1.8*" MinWidth="150" ElementStyle="{StaticResource GridCellTextStyle}" />
                                    <DataGridTemplateColumn Header="{DynamicResource LblType}" Width="1.2*" MinWidth="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border x:Name="DiscountTypeBadge" Style="{StaticResource TypeBadgeBorder}">
                                                    <TextBlock x:Name="DiscountTypeText" Text="{Binding Type}" Style="{StaticResource TypeBadgeText}" />
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="Manufacturing">
                                                        <Setter TargetName="DiscountTypeBadge" Property="Background" Value="#FDF2FA" />
                                                        <Setter TargetName="DiscountTypeBadge" Property="BorderBrush" Value="#F4D5EA" />
                                                        <Setter TargetName="DiscountTypeText" Property="Foreground" Value="#C11574" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Improvement">
                                                        <Setter TargetName="DiscountTypeBadge" Property="Background" Value="#ECFDF3" />
                                                        <Setter TargetName="DiscountTypeBadge" Property="BorderBrush" Value="#ABEFC6" />
                                                        <Setter TargetName="DiscountTypeText" Property="Foreground" Value="#067647" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="{DynamicResource LblAmount}" Binding="{Binding Amount, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}" Width="1.1*" MinWidth="110" ElementStyle="{StaticResource GridCellTextStyle}" />
                                    <DataGridTextColumn Header="{DynamicResource LblNotes}" Binding="{Binding Notes}" Width="2*" MinWidth="180" ElementStyle="{StaticResource GridCellTextStyle}" />
                                    <DataGridTemplateColumn Header="..." Width="104">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Menu Style="{StaticResource GridActionMenu}" HorizontalAlignment="Center">
                                                    <MenuItem Header="{DynamicResource BtnMore}" Style="{StaticResource GridActionMenuItem}">
                                                        <MenuItem Header="{DynamicResource BtnViewDetails}" Command="{Binding DataContext.ViewDiscountRowCommand, Source={x:Reference Root}}" CommandParameter="{Binding}" />
                                                        <MenuItem Header="{DynamicResource BtnEdit}" Command="{Binding DataContext.EditDiscountRowCommand, Source={x:Reference Root}}" CommandParameter="{Binding}" />
                                                        <MenuItem Header="{DynamicResource BtnDelete}" Command="{Binding DataContext.DeleteDiscountRowCommand, Source={x:Reference Root}}" CommandParameter="{Binding}" />
                                                    </MenuItem>
                                                </Menu>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border Grid.Row="1" Background="#F8FAFC" Visibility="{Binding Discounts.Count, Converter={StaticResource ZeroCountToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="PercentBoxOutline" Width="42" Height="42" Foreground="#98A2B3" HorizontalAlignment="Center" />
                                    <TextBlock Text="{DynamicResource LblEmptyDiscountsTitle}" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,6" HorizontalAlignment="Center" />
                                    <TextBlock Text="{DynamicResource LblEmptyDiscountsSub}" Foreground="#667085" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1,1,1,0" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Padding="12,8" Background="#FFFFFF" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="12" Margin="0,0,12,0" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding DiscountsRowsCountLabel}" FontWeight="SemiBold" Foreground="#344054" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Border Padding="12,8" Background="#FFFFFF" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="12" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding DiscountsPageSummary}" FontWeight="SemiBold" Foreground="#344054" />
                                        </Border>
                                        <Border Padding="12,8" Background="#FFF7E2" BorderBrush="#F0DFA7" BorderThickness="1" CornerRadius="12">
                                            <TextBlock Text="{Binding DiscountsSelectedCountLabel}" FontWeight="SemiBold" Foreground="#8A6C00" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Command="{Binding PreviousDiscountsPageCommand}" Style="{StaticResource CompactToolbarButton}" MinWidth="74" Margin="0,0,8,0">
                                            <TextBlock Text="{DynamicResource BtnPreviousPage}" />
                                        </Button>
                                        <Button Command="{Binding NextDiscountsPageCommand}" Style="{StaticResource CompactToolbarButton}" MinWidth="74" Margin="0">
                                            <TextBlock Text="{DynamicResource BtnNextPage}" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
                </TabControl>

                <Border Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#B3FFFFFF">
                    <Border Style="{StaticResource LoadingOverlayCard}">
                        <StackPanel>
                            <ProgressBar IsIndeterminate="True" Width="180" Height="6" Margin="0,0,0,14" />
                            <TextBlock Text="{Binding BusyMessage}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
