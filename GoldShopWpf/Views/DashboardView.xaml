<UserControl x:Class="GoldShopWpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <UserControl.Resources>
        <DropShadowEffect x:Key="DashboardShadow" BlurRadius="22" ShadowDepth="2" Opacity="0.14" />

        <Style x:Key="DashboardMetricCard" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="BorderBrush" Value="#D9E2F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect" Value="{StaticResource DashboardShadow}" />
            <Setter Property="MinHeight" Value="154" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                        <TranslateTransform Y="0" />
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.18" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.18" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" To="-2" Duration="0:0:0.18" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.18" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.18" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)" To="0" Duration="0:0:0.18" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Margin="0,0,0,18"
                    Padding="28"
                    CornerRadius="28"
                    BorderBrush="#E8E1CF"
                    BorderThickness="1"
                    Effect="{StaticResource DashboardShadow}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFF9EC" Offset="0" />
                        <GradientStop Color="#FFF2D1" Offset="0.55" />
                        <GradientStop Color="#F7E6BF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{DynamicResource LblOverview}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="{DynamicResource LblOverviewSub}"
                                   FontSize="15"
                                   Foreground="#6B5B2A"
                                   Margin="0,0,0,18" />

                        <WrapPanel>
                            <Border Background="#FFFFFF"
                                    BorderBrush="#E6D7A9"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="14,10"
                                    Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CashMultiple" Width="18" Height="18" Foreground="#AF8600" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding TotalGold21, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}"
                                               FontWeight="Bold"
                                               FontSize="16" />
                                </StackPanel>
                            </Border>
                            <Border Background="#FFFFFF"
                                    BorderBrush="#E6D7A9"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="14,10">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountGroup" Width="18" Height="18" Foreground="#AF8600" Margin="0,0,8,0" />
                                    <TextBlock FontWeight="Bold"
                                               FontSize="16">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding SupplierCount, StringFormat=Active Traders: {0}}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=FlowDirection}" Value="RightToLeft">
                                                        <Setter Property="Text" Value="{Binding SupplierCount, StringFormat=التجار النشطون: {0}}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button Command="{Binding AddSupplierCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,10,0"
                                MinWidth="148">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnAddTrader}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding AddTransactionCommand}"
                                Style="{StaticResource GhostButton}"
                                MinWidth="164">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CashFast" Width="18" Height="18" Margin="0,0,6,0" />
                                <TextBlock Text="{DynamicResource BtnAddTransaction}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <UniformGrid Columns="4" Margin="0,0,0,18">
                <Border Style="{StaticResource DashboardMetricCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Width="42" Height="42" CornerRadius="14" Background="#EEF4FF" BorderBrush="#D6E4FF" BorderThickness="1" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Gold" Width="20" Height="20" Foreground="#2457C5" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <TextBlock Text="{DynamicResource LblTotalGold21}" FontSize="13" FontWeight="SemiBold" Foreground="#667085" HorizontalAlignment="Center" />
                            <TextBlock Text="{DynamicResource LblDashboardGoldSub}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" HorizontalAlignment="Center" TextAlignment="Center" />
                            <TextBlock Text="{Binding TotalGold21, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='g'}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource DashboardMetricCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Width="42" Height="42" CornerRadius="14" Background="#FDF2FA" BorderBrush="#F4D5EA" BorderThickness="1" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Factory" Width="20" Height="20" Foreground="#C11574" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <TextBlock Text="{DynamicResource LblFinalManufacturing}" FontSize="13" FontWeight="SemiBold" Foreground="#667085" HorizontalAlignment="Center" />
                            <TextBlock Text="{DynamicResource LblDashboardManufacturingSub}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" HorizontalAlignment="Center" TextAlignment="Center" />
                            <TextBlock Text="{Binding FinalManufacturing, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource DashboardMetricCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Width="42" Height="42" CornerRadius="14" Background="#ECFDF3" BorderBrush="#ABEFC6" BorderThickness="1" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="TrendingUp" Width="20" Height="20" Foreground="#067647" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <TextBlock Text="{DynamicResource LblFinalImprovement}" FontSize="13" FontWeight="SemiBold" Foreground="#667085" HorizontalAlignment="Center" />
                            <TextBlock Text="{DynamicResource LblDashboardImprovementSub}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" HorizontalAlignment="Center" TextAlignment="Center" />
                            <TextBlock Text="{Binding FinalImprovement, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource DashboardMetricCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Width="42" Height="42" CornerRadius="14" Background="#EEF4FF" BorderBrush="#D6E4FF" BorderThickness="1" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="20" Height="20" Foreground="#2457C5" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <TextBlock Text="{DynamicResource LblTraders}" FontSize="13" FontWeight="SemiBold" Foreground="#667085" HorizontalAlignment="Center" />
                            <TextBlock Text="{DynamicResource LblDashboardTradersSub}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" HorizontalAlignment="Center" TextAlignment="Center" />
                            <TextBlock Text="{Binding SupplierCount}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <UniformGrid Columns="2" Margin="0,0,0,18">
                <Border Style="{StaticResource DashboardMetricCard}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LblDiscountImpact}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBlock Text="{DynamicResource LblDiscountImpactSub}" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,14" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Padding="18"
                                    CornerRadius="18"
                                    Background="#FFF6F2"
                                    BorderBrush="#F3DDD4"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LblManufacturingDiscounts}" FontSize="12" Foreground="#9A3412" />
                                    <TextBlock Text="{Binding ManufacturingDiscounts, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#C2410C"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="18"
                                    CornerRadius="18"
                                    Background="#FFF6F2"
                                    BorderBrush="#F3DDD4"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LblImprovementDiscounts}" FontSize="12" Foreground="#9A3412" />
                                    <TextBlock Text="{Binding ImprovementDiscounts, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#C2410C"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DashboardMetricCard}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LblLast7Days}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBlock Text="{DynamicResource LblLast7DaysSub}" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,14" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Padding="18"
                                    CornerRadius="18"
                                    Background="#F6F9FF"
                                    BorderBrush="#E2EAFB"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LblFinalManufacturing}" FontSize="12" Foreground="#475467" />
                                    <TextBlock Text="{Binding TotalManufacturingThisWeek, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="18"
                                    CornerRadius="18"
                                    Background="#F6F9FF"
                                    BorderBrush="#E2EAFB"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LblFinalImprovement}" FontSize="12" Foreground="#475467" />
                                    <TextBlock Text="{Binding TotalImprovementThisWeek, Converter={StaticResource MoneyFormatConverter}, ConverterParameter='EGP'}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.4*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DashboardMetricCard}"
                        Margin="8,8,12,8">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LblHighestGoldBalance}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBlock Text="{DynamicResource LblHighestGoldBalanceSub}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,18" />
                        <ItemsControl ItemsSource="{Binding SupplierBalanceBars}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="58" Margin="5,0" VerticalAlignment="Bottom">
                                        <Border Background="#E6B91E" Height="{Binding Height}" CornerRadius="7,7,4,4" />
                                        <TextBlock Text="{Binding Value, StringFormat={}{0:0.#}}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center"
                                                   Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding Label}"
                                                   TextWrapping="Wrap"
                                                   FontSize="10"
                                                   TextAlignment="Center"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource DashboardMetricCard}"
                        Margin="12,8,8,8">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LblGoldVsCosts}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <TextBlock Text="{DynamicResource LblGoldVsCostsSub}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,18" />
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="220" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#FCFCFD"
                                    CornerRadius="18"
                                    BorderBrush="#E9EDF5"
                                    BorderThickness="1"
                                    Padding="14">
                                <Viewbox Stretch="Uniform" Height="190">
                                    <Canvas Height="200" Width="520">
                                        <Polyline Points="{Binding GoldLinePoints}" Stroke="#E0AA00" StrokeThickness="3" StrokeLineJoin="Round" />
                                        <Polyline Points="{Binding PaymentLinePoints}" Stroke="#2E7D32" StrokeThickness="3" StrokeLineJoin="Round" />
                                    </Canvas>
                                </Viewbox>
                            </Border>

                            <ItemsControl Grid.Row="1" ItemsSource="{Binding GoldPaymentLabels}" Margin="0,14,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="7" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="10" TextAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
