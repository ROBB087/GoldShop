<Window x:Class="GoldShopWpf.Views.SupplierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Trader" Height="420" Width="520" MinWidth="400" MinHeight="300" WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        FlowDirection="{DynamicResource AppFlowDirection}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="{DynamicResource LblName}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="8" />
        <TextBox x:Name="NameText" Grid.Row="0" Grid.Column="1" Margin="0,8" MinHeight="30" />

        <TextBlock Text="{DynamicResource LblPhone}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="8" />
        <TextBox x:Name="PhoneText" Grid.Row="1" Grid.Column="1" Margin="0,8" MinHeight="30" />

        <TextBlock Text="{DynamicResource LblContactName}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="8" />
        <TextBox x:Name="WorkerNameText" Grid.Row="2" Grid.Column="1" Margin="0,8" MinHeight="30" />

        <TextBlock Text="{DynamicResource LblContactPhone}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="8" />
        <TextBox x:Name="WorkerPhoneText" Grid.Row="3" Grid.Column="1" Margin="0,8" MinHeight="30" />

        <TextBlock Text="{DynamicResource LblNotes}" Grid.Row="4" Grid.Column="0" VerticalAlignment="Top" Margin="8" />
        <TextBox x:Name="NotesText" Grid.Row="4" Grid.Column="1" Margin="0,8" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100" />

        <StackPanel Orientation="Horizontal" Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" Margin="8,16,0,0">
            <Button Width="120" Style="{StaticResource PrimaryButton}" Margin="8,16,0,0" Click="OnSave" ToolTip="{DynamicResource BtnApply}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="{DynamicResource BtnApply}" />
                </StackPanel>
            </Button>
            <Button Width="110" Style="{StaticResource GhostButton}" Margin="8,16,0,0" Click="OnCancel" ToolTip="{DynamicResource BtnClear}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CloseCircle" Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="{DynamicResource BtnClear}" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>

