<UserControl x:Class="GoldShopWpf.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="24">
        <Border Style="{StaticResource CardContainer}" Padding="28" BorderBrush="#D7DEEC">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{DynamicResource NavBackup}" FontSize="26" FontWeight="SemiBold" Foreground="#0F172A" />
                    <TextBlock Text="{DynamicResource LblBackupSub}"
                               FontSize="14"
                               Foreground="#475467"
                               Margin="0,6,0,20" />
                    <Border Padding="16" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource BtnBackup}" FontWeight="SemiBold" />
                            <TextBlock Text="{DynamicResource LblBackupAutoSub}"
                                       Foreground="#667085"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <WrapPanel Grid.Row="1" Margin="0,20,0,0">
                    <Button Command="{Binding BackupCommand}" Style="{StaticResource PrimaryButton}" MinWidth="170" Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseArrowUp" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource BtnBackup}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RestoreCommand}" Style="{StaticResource GhostButton}" MinWidth="170" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseRefreshOutline" Margin="0,0,6,0" />
                            <TextBlock Text="{DynamicResource BtnRestore}" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
