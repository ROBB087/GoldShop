<Application x:Class="GoldShopWpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GoldShopWpf"
             xmlns:converters="clr-namespace:GoldShopWpf.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Strings.ar.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Colors -->
            <SolidColorBrush x:Key="GoldBrush" Color="#FFD700" />
            <SolidColorBrush x:Key="GoldDarkBrush" Color="#C9A300" />
            <SolidColorBrush x:Key="AccentGreenBrush" Color="#2E7D32" />

            <!-- Light Mode App -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextBrush" Color="#1E1E1E" />
            <SolidColorBrush x:Key="MutedTextBrush" Color="#666666" />
            <SolidColorBrush x:Key="GridBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="GridAltRowBrush" Color="#F5F5F5" />
            <SolidColorBrush x:Key="GridHeaderBrush" Color="#F0F0F0" />
            <SolidColorBrush x:Key="GridLineBrush" Color="#DDDDDD" />
            <SolidColorBrush x:Key="GridTextBrush" Color="#1E1E1E" />
            <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="InputBorderBrush" Color="#CCCCCC" />
            <SolidColorBrush x:Key="GhostButtonBrush" Color="#EFE7D5" />
            <SolidColorBrush x:Key="GhostButtonHoverBrush" Color="#E5D7B8" />
            <SolidColorBrush x:Key="GoldValueBrush" Color="#FFD700" />

            <!-- Sidebar Dark -->
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1E1E1E" />
            <SolidColorBrush x:Key="SidebarTextBrush" Color="#FFFFFF" />

            <!-- Fonts -->
            <FontFamily x:Key="AppFontFamily">Segoe UI</FontFamily>
            <FlowDirection x:Key="AppFlowDirection">RightToLeft</FlowDirection>

            <!-- Window Style -->
            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
                <Setter Property="FlowDirection" Value="{DynamicResource AppFlowDirection}" />
            </Style>

            <!-- TextBlock -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            </Style>

            <!-- Card -->
            <Style x:Key="CardContainer" TargetType="Border">
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Background" Value="{DynamicResource CardBrush}" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="8" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- PrimaryButton -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="Background" Value="{StaticResource GoldBrush}" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource GoldDarkBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.6" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- GhostButton -->
            <Style x:Key="GhostButton" TargetType="Button">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="Background" Value="{DynamicResource GhostButtonBrush}" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource GhostButtonHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.6" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- SidebarButton -->
            <Style x:Key="SidebarButton" TargetType="Button">
                <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
                <Setter Property="Background" Value="{DynamicResource SidebarBackgroundBrush}" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2B2B2B" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.6" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TextBox / ComboBox / DatePicker / Calendar -->
            <Style TargetType="TextBox">
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
                <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="FlowDirection" Value="{DynamicResource AppFlowDirection}" />
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="FlowDirection" Value="{DynamicResource AppFlowDirection}" />
            </Style>

            <Style TargetType="DatePicker">
                <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="FlowDirection" Value="{DynamicResource AppFlowDirection}" />
            </Style>

            <Style TargetType="Calendar">
                <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="FlowDirection" Value="{DynamicResource AppFlowDirection}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8" />
            </Style>

            <Style TargetType="CalendarDayButton">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                <Setter Property="Margin" Value="2" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CalendarDayButton">
                            <Border x:Name="DayBorder" Background="Transparent" CornerRadius="8" Padding="6,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsToday" Value="True">
                                    <Setter TargetName="DayBorder" Property="Background" Value="{DynamicResource GoldBrush}" />
                                    <Setter Property="Foreground" Value="#1A1A1A" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="DayBorder" Property="Background" Value="#EDEDED" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="DayBorder" Property="Background" Value="#DADADA" />
                                </Trigger>
                                <Trigger Property="IsInactive" Value="True">
                                    <Setter Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsToday" Value="True">
                        <Setter Property="Background" Value="{DynamicResource GoldBrush}" />
                        <Setter Property="Foreground" Value="#1A1A1A" />
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#EDEDED" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- DataGrid -->
            <Style TargetType="DataGrid">
                <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Foreground" Value="{DynamicResource GridTextBrush}" />
                <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
                <Setter Property="RowBackground" Value="{DynamicResource GridBackgroundBrush}" />
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridAltRowBrush}" />
                <Setter Property="GridLinesVisibility" Value="Horizontal" />
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource GridLineBrush}" />
                <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource GridLineBrush}" />
                <Setter Property="HeadersVisibility" Value="Column" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FlowDirection" Value="{DynamicResource AppFlowDirection}" />
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource GridTextBrush}" />
                <Setter Property="Padding" Value="8" />
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource GridTextBrush}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#EDEDED" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#E0E0E0" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Page Transition -->
            <Style TargetType="ContentControl" x:Key="PageTransition">
                <Setter Property="Opacity" Value="0" />
                <Style.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <!-- Converters -->
            <converters:TransactionTypeToBrushConverter x:Key="TransactionTypeToBrushConverter" />
            <converters:TransactionTypeToLabelConverter x:Key="TransactionTypeToLabelConverter" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
