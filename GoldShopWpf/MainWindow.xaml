<Window x:Class="GoldShopWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GoldShopWpf.ViewModels"
        xmlns:views="clr-namespace:GoldShopWpf.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        FlowDirection="{DynamicResource AppFlowDirection}"
        Title="{DynamicResource LblAppTitle}" Height="820" Width="1366" MinWidth="1180" MinHeight="760" WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SuppliersViewModel}">
            <views:SuppliersView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierDetailsViewModel}">
            <views:SupplierDetailsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TransactionsViewModel}">
            <views:TransactionsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WeeklyReportViewModel}">
            <views:WeeklyReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StatementViewModel}">
            <views:StatementView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NotesViewModel}">
            <views:NotesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PricingSettingsViewModel}">
            <views:PricingSettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BackupViewModel}">
            <views:BackupView />
        </DataTemplate>
    </Window.Resources>

    <Grid FlowDirection="{DynamicResource AppFlowDirection}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{DynamicResource SidebarBackgroundBrush}" Grid.Column="0">
            <StackPanel Margin="16">
                <StackPanel Orientation="Horizontal" Margin="0,10,0,24">
                    <Border Width="34" Height="34" Background="#FFF8E1" CornerRadius="10" Padding="4">
                        <Image Source="Resources/logo.png" Stretch="Uniform" />
                    </Border>
                    <TextBlock Text="{DynamicResource LblAppTitle}" Foreground="{DynamicResource SidebarTextBrush}" FontSize="18" FontWeight="SemiBold" Margin="10,0,0,0" />
                </StackPanel>

                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowDashboardCommand}" ToolTip="{DynamicResource TooltipDashboard}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="4" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource GoldBrush}" CornerRadius="999">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Dashboard}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                            <materialDesign:PackIcon Kind="Home" Width="18" Height="18" Margin="0,0,10,0">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon" BasedOn="{StaticResource {x:Type materialDesign:PackIcon}}">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarIconBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Dashboard}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource GoldBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock Text="{DynamicResource NavDashboard}" TextWrapping="NoWrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Dashboard}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource GoldBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowSuppliersCommand}" ToolTip="{DynamicResource TooltipSuppliers}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="4" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource GoldBrush}" CornerRadius="999">
                            <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Suppliers}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style>
                        </Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="18" Height="18" Margin="0,0,10,0">
                                <materialDesign:PackIcon.Style><Style TargetType="materialDesign:PackIcon" BasedOn="{StaticResource {x:Type materialDesign:PackIcon}}"><Setter Property="Foreground" Value="{StaticResource SidebarIconBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Suppliers}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock Text="{DynamicResource NavSuppliers}" TextWrapping="NoWrap"><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}"><Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Suppliers}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowTransactionsCommand}" ToolTip="{DynamicResource TooltipTransactions}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="4" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource GoldBrush}" CornerRadius="999"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Transactions}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style></Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                            <materialDesign:PackIcon Kind="Cash" Width="18" Height="18" Margin="0,0,10,0"><materialDesign:PackIcon.Style><Style TargetType="materialDesign:PackIcon" BasedOn="{StaticResource {x:Type materialDesign:PackIcon}}"><Setter Property="Foreground" Value="{StaticResource SidebarIconBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Transactions}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></materialDesign:PackIcon.Style></materialDesign:PackIcon>
                            <TextBlock Text="{DynamicResource NavTransactions}" TextWrapping="NoWrap"><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}"><Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Transactions}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowSupplierDetailsCommand}" ToolTip="{DynamicResource TooltipSupplierDetails}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="4" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource GoldBrush}" CornerRadius="999"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=SupplierDetails}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style></Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                            <materialDesign:PackIcon Kind="AccountDetails" Width="18" Height="18" Margin="0,0,10,0"><materialDesign:PackIcon.Style><Style TargetType="materialDesign:PackIcon" BasedOn="{StaticResource {x:Type materialDesign:PackIcon}}"><Setter Property="Foreground" Value="{StaticResource SidebarIconBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=SupplierDetails}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></materialDesign:PackIcon.Style></materialDesign:PackIcon>
                            <TextBlock Text="{DynamicResource NavSupplierDetails}" TextWrapping="NoWrap"><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}"><Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=SupplierDetails}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowWeeklyReportCommand}" ToolTip="{DynamicResource TooltipWeeklyReport}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="4" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource GoldBrush}" CornerRadius="999"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=WeeklyReport}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style></Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                            <materialDesign:PackIcon Kind="ChartLine" Width="18" Height="18" Margin="0,0,10,0"><materialDesign:PackIcon.Style><Style TargetType="materialDesign:PackIcon" BasedOn="{StaticResource {x:Type materialDesign:PackIcon}}"><Setter Property="Foreground" Value="{StaticResource SidebarIconBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=WeeklyReport}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></materialDesign:PackIcon.Style></materialDesign:PackIcon>
                            <TextBlock Text="{DynamicResource NavWeeklyReport}" TextWrapping="NoWrap"><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}"><Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=WeeklyReport}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowStatementCommand}" ToolTip="{DynamicResource TooltipStatement}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="4" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource GoldBrush}" CornerRadius="999"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Statement}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style></Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                            <materialDesign:PackIcon Kind="FileDocumentOutline" Width="18" Height="18" Margin="0,0,10,0"><materialDesign:PackIcon.Style><Style TargetType="materialDesign:PackIcon" BasedOn="{StaticResource {x:Type materialDesign:PackIcon}}"><Setter Property="Foreground" Value="{StaticResource SidebarIconBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Statement}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></materialDesign:PackIcon.Style></materialDesign:PackIcon>
                            <TextBlock Text="{DynamicResource NavStatement}" TextWrapping="NoWrap"><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}"><Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Statement}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowNotesCommand}" ToolTip="{DynamicResource TooltipNotes}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="4" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource GoldBrush}" CornerRadius="999"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Notes}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style></Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                            <materialDesign:PackIcon Kind="NotebookOutline" Width="18" Height="18" Margin="0,0,10,0"><materialDesign:PackIcon.Style><Style TargetType="materialDesign:PackIcon" BasedOn="{StaticResource {x:Type materialDesign:PackIcon}}"><Setter Property="Foreground" Value="{StaticResource SidebarIconBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Notes}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></materialDesign:PackIcon.Style></materialDesign:PackIcon>
                            <TextBlock Text="{DynamicResource NavNotes}" TextWrapping="NoWrap"><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}"><Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Notes}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowPricingSettingsCommand}" ToolTip="{DynamicResource TooltipPricingSettings}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="4" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource GoldBrush}" CornerRadius="999"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=PricingSettings}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style></Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                            <materialDesign:PackIcon Kind="TuneVariant" Width="18" Height="18" Margin="0,0,10,0"><materialDesign:PackIcon.Style><Style TargetType="materialDesign:PackIcon" BasedOn="{StaticResource {x:Type materialDesign:PackIcon}}"><Setter Property="Foreground" Value="{StaticResource SidebarIconBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=PricingSettings}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></materialDesign:PackIcon.Style></materialDesign:PackIcon>
                            <TextBlock Text="{DynamicResource NavPricingSettings}" TextWrapping="NoWrap"><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}"><Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=PricingSettings}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        </StackPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource SidebarButton}" Command="{Binding ShowBackupCommand}" ToolTip="{DynamicResource TooltipBackup}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="4" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource GoldBrush}" CornerRadius="999"><Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Backup}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Border.Style></Border>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                            <materialDesign:PackIcon Kind="Database" Width="18" Height="18" Margin="0,0,10,0"><materialDesign:PackIcon.Style><Style TargetType="materialDesign:PackIcon" BasedOn="{StaticResource {x:Type materialDesign:PackIcon}}"><Setter Property="Foreground" Value="{StaticResource SidebarIconBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Backup}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></materialDesign:PackIcon.Style></materialDesign:PackIcon>
                            <TextBlock Text="{DynamicResource NavBackup}" TextWrapping="NoWrap"><TextBlock.Style><Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}"><Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" /><Style.Triggers><DataTrigger Binding="{Binding ActivePageKey, Converter={StaticResource ActivePageMatchConverter}, ConverterParameter=Backup}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoldBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                        </StackPanel>
                    </Grid>
                </Button>
            </StackPanel>
        </Border>

        <DockPanel Grid.Column="1" Background="{DynamicResource AppBackgroundBrush}">
            <Border Background="#FFFFFF" DockPanel.Dock="Top" Padding="20" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding PageTitle}" FontSize="20" FontWeight="SemiBold" />
                    <WrapPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
                        <Border Background="#FFF7E2"
                                BorderBrush="#F0DFA7"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12,8"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding LicensedToDisplay}"
                                       FontWeight="SemiBold"
                                       Foreground="#7A5A00" />
                        </Border>
                        <Button Content="{DynamicResource BtnBackup}" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Command="{Binding BackupCommand}" ToolTip="{DynamicResource BtnBackup}" />
                        <Button Content="{DynamicResource BtnToggleLang}" Style="{StaticResource GhostButton}" Command="{Binding ToggleLanguageCommand}" ToolTip="{DynamicResource TooltipToggleLanguage}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Margin="16">
                <ContentControl Content="{Binding CurrentPage}" Style="{StaticResource PageTransition}" />

                <ItemsControl ItemsSource="{Binding Toasts}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Margin="0,12,12,0"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12"
                                    Padding="16,14"
                                    CornerRadius="16"
                                    MinWidth="220"
                                    MaxWidth="360"
                                    Opacity="0.98">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource ToastSuccessBrush}" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="18" ShadowDepth="4" Color="#22000000" Opacity="0.25" />
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:ToastKind.Warning}">
                                                <Setter Property="Background" Value="{DynamicResource ToastWarningBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:ToastKind.Error}">
                                                <Setter Property="Background" Value="{DynamicResource ToastErrorBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="0.98" Duration="0:0:0.18" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <TextBlock Text="{Binding Message}"
                                           Foreground="{DynamicResource ToastForegroundBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
